ed by 'connecting branch of' some 'thoracic aorta'.\\n\\n\\n\",\n  \"comments\": [\n    {\n      \"id\": \"IC_kwDOAAidd86z7QJX\",\n      \"author\": {\n        \"login\": \"aleixpuigb\"\n      },\n      \"authorAssociation\": \"MEMBER\",\n      \"body\": \"@dragon-ai-agent please make these changes.\",\n      \"createdAt\": \"2025-06-30T10:38:34Z\",\n      \"includesCreatedEdit\": false,\n      \"isMinimized\": false,\n      \"minimizedReason\": \"\",\n      \"reactionGroups\": [],\n      \"url\": \"https://github.com/obophenotype/uberon/issues/3572#issuecomment-3018654295\",\n      \"viewerDidAuthor\": false\n    }\n  ],\n  \"title\": \"Revise esophagus and esophageal artery partonomy\",","truncated":false,"loaded":[]},"title":"__issue_context__.json","time":{"start":1778554863012,"end":1778554863024}},"id":"prt_e1a217a7c0018VsQm8EgN007W6","sessionID":"ses_1e5df3adaffewQchdUfb2JYP8w","messageID":"msg_e1a20c5e9001I1gG9KCL3RxRoZ"}}
