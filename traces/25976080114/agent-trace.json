us)\");\n-    create_axiom(\"%object_id EquivalentTo: %subject_id and (BFO:0000066 some NCBITaxon:8353)\");\n+    create_axiom(\"%object_id EquivalentTo: %subject_id and (RO:0002162 some NCBITaxon:8353)\");\n }\ndiff --git a/src/ontology/bridge/bridges.rules b/src/ontology/bridge/bridges.rules\nindex 7b7a41c..d986d30 100644\n--- a/src/ontology/bridge/bridges.rules\n+++ b/src/ontology/bridge/bridges.rules\n@@ -24,11 +24,11 @@ prefix UBERON:    <http://purl.obolibrary.org/obo/UBERON_>\n \n # The relation to use in the existential restrictions between Uberon/CL\n # terms and their taxon-specific equivalents: part_of (BFO:0000050) for\n-# most cases, except for life stage terms where we use occurs_in\n-# (BFO:0000066) instead.\n+# most cases, except for life stage terms where we use in taxon\n+# (RO:0002162) instead.\n set_var(\"TAXREL\", BFO:0000050);\n-is_a(%{object_id}, UBERON:0000104) -> set_var(\"TAXREL\", BFO:0000066);\n-is_a(%{object_id}, UBERON:0000105) -> set_var(\"TAXREL\", BFO:0000066);\n+is_a(%{object_id}, UBERON:0000104) -> set_var(\"TAXREL\", RO:0002162);\n+is_a(%{object_id}, UBERON:0000105) -> set_var(\"TAXREL\", RO:0002162);\n \n # Make sure UBERON and CL classes are on the object side.\n subject==UBERON:* || subject==CL:* -> invert();\ndiff --git a/src/ontology/bridge/uberon-bridge-to-fbdv.owl b/src/ontology/bridge/uberon-bridge-to-fbdv.owl\nindex b37d4d5..b9f6f9f 100644\n--- a/src/ontology/bridge/uberon-bridge-to-fbdv.owl\n+++ b/src/ontology/bridge/uberon-bridge-to-fbdv.owl\n@@ -41,9 +41,9 @@\n     \n \n \n-    <!-- http://purl.obolibrary.org/obo/BFO_0000066 -->\n+    <!-- http://purl.obolibrary.org/obo/RO_0002162 -->\n \n-    <owl:ObjectProperty rdf:about=\"http://purl.obolibrary.org/obo/BFO_0000066\"/>\n+    <owl:ObjectProperty rdf:about=\"http://purl.obolibrary.org/obo/RO_0002162\"/>\n     \n \n \n@@ -66,7 +66,7 @@\n                 <owl:intersectionOf rdf:parseType=\"Collection\">\n                     <rdf:Description rdf:about=\"http://purl.oboli