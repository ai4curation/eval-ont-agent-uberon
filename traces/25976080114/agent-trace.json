{"type":"tool_use","timestamp":1778975296641,"sessionID":"ses_1cccff35bffef2xqhPYhjIHD90","part":{"type":"tool","tool":"read","callID":"call_E38bfyLshG20OJYGLuBG1HgA","state":{"status":"completed","input":{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/scripts/taxa.py","offset":1,"limit":140},"output":"<path>/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/scripts/taxa.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \n3: # HELPER SCRIPT TO MANAGE TAXA\n4: #\n5: # Uberon bridging and compositing processes require a bit of information\n6: # about the taxa that are involved. To make it easier to manage those\n7: # informations, they are centralised in the config/taxa.yaml file.\n8: #\n9: # The main contents of the config/taxa.yaml file is a list of taxa,\n10: # where each taxon is represented by a structure that should look like\n11: # this:\n12: #\n13: # ---8<-----\n14: # taxon_id: NCBITaxon:1234\n15: # label: <human-readable suffix to append to term labels>\n16: # compositing:\n17: #   unfold_over: <list of properties to unfold tax-specific terms over\n18: #                (defaults to BFO:0000050, BFO:0000066)>\n19: #   preserve: <list of properties that should be preserved when unfolding>\n20: # bridging:\n21: #   - prefix: <prefix of taxon-specific terms>\n22: #     namespace: <IRI namespace the prefix expands to\n23: #                 (defaults to http://purl.obolibrary.org/obo/prefix_)>\n24: #     name: <bridge name (defaults to lowercase prefix)\n25: #   [possibly other bridges for the same taxon]\n26: # --->8-----\n27: #\n28: # Currently, this file is used for two things:\n29: #\n30: # (1) automatically generate the SSSOM/T-OWL rules needed to generate\n31: #     the cross-species bridge files (taxa.py make-rules);\n32: #\n33: # (2) automatically generate the batch file used by the\n34: #     uberon:merge-species command to create the composite ontologies.\n35: \n36: import sys\n37: import yaml\n38: \n39: def generate_prefix_declarations(f, taxa):\n40:     \"\"\"Insert SSSOM/T-OWL prefix declarations for all species.\"\"\"\n41:     for taxon in taxa['species']:\n42:         for bridge in taxon['bridging']:\n43:             prefix = bridge['prefix']\n44:             namespace = bridge.get('namespace', 'http://purl.obolibrary.org/obo/' + prefix + '_')\n45: \n46:             f.write(f\"prefix {prefix}: <{namespace}>\\n\")\n47: \n48: \n49: def generate_directives(f, taxa):\n50:     \"\"\"Insert SSSOM/T-OWL taxon declarations for all species.\"\"\"\n51:     for taxon_id in [t['taxon_id'] for t in taxa['species']]:\n52:         f.write(f\"declare({taxon_id});\\n\")\n53: \n54: \n55: def generate_bridging_rules(f, taxa):\n56:     \"\"\"Insert SSSOM/T-OWL bridging rules for all species.\"\"\"\n57:     for taxon in taxa['species']:\n58:         taxon_id = taxon['taxon_id']\n59:         def_label = taxon['label']\n60:         for bridge in taxon['bridging']:\n61:             prefix = bridge['prefix']\n62:             name = bridge.get('name', prefix.lower())\n63:             label = bridge.get('label', def_label)\n64: \n65:             f.write(f\"\"\"\n66: [{name}-uberon] subject=={prefix}:* object==UBERON:* {{\n67:     predicate==* -> annotate(%{{subject_id}}, IAO:0000589, \"%{{object_label}} ({label})\");\n68:     predicate==semapv:crossSpeciesExactMatch -> create_axiom(\"%subject_id EquivalentTo: %object_id and (%TAXREL some {taxon_id})\");\n69: }}\n70: [{name}-cl] subject=={prefix}:* object==CL:* {{\n71:     predicate==* -> annotate(%{{subject_id}}, IAO:0000589, \"%{{object_label}} ({label})\");\n72:     predicate==semapv:crossSpeciesExactMatch -> create_axiom(\"%subject_id EquivalentTo: %object_id and (%TAXREL some {taxon_id})\");\n73: }}\n74: \"\"\")\n75: \n76: \n77: def process_rule_file(filein, fileout, taxa):\n78:     \"\"\"Insert all SSSOM/T-OWL instructions required to generate\n79:         cross-species bridges.\n80:     \"\"\"\n81: \n82:     for line in filein:\n83:         if line.strip() == '%INSERT-TAX-SPECIFIC-PREFIXES':\n84:             generate_prefix_declarations(fileout, taxa)\n85:         elif line.strip() == '%INSERT-TAX-SPECIFIC-DIRECTIVES':\n86:             generate_directives(fileout, taxa)\n87:         elif line.strip() == '%INSERT-TAX-SPECIFIC-BRIDGES':\n88:             generate_bridging_rules(fileout, taxa)\n89:         else:\n90:             fileout.write(line)\n91: \n92: \n93: def generate_merge_table(fileout, taxa):\n94:     \"\"\"Generates a batch-file for uberon:merge-species.\"\"\"\n95:     def_link_properties = taxa.get('defaults', {}).get('compositing', {}).get('unfold_over', ['BFO:0000050', 'BFO:0000066'])\n96:     def_preserved_properties = taxa.get('defaults', {}).get('compositing', {}).get('preserve', [])\n97: \n98:     for taxon in taxa['species']:\n99:         taxon_id = taxon['taxon_id']\n100:         label = taxon['label']\n101:         link_properties = ','.join(taxon.get('compositing', {}).get('unfold_over', def_link_properties))\n102:         preserved_properties = ','.join(taxon.get('compositing', {}).get('preserve', def_preserved_properties))\n103: \n104:         fileout.write(f\"{taxon_id}\\t{label}\\t{link_properties}\\t{preserved_properties}\\n\")\n105: \n106: \n107: def read_taxa_file(file):\n108:     with open(file, 'r') as f:\n109:         return yaml.load(f, yaml.CLoader)\n110: \n111: \n112: usage = f\"Usage: {sys.argv[0]} <make-rules TAXA TEMPLATE> | <make-merge-table TAXA>\"\n113: if len(sys.argv) < 2:\n114:     sys.exit(usage)\n115: \n116: cmd = sys.argv[1]\n117: if cmd == 'make-rules':\n118:     if len(sys.argv) != 4:\n119:         sys.exit(usage)\n120:     taxa = read_taxa_file(sys.argv[2])\n121:     with open(sys.argv[3], 'r') as fin:\n122:         process_rule_file(fin, sys.stdout, taxa)\n123: elif cmd == 'make-merge-table':\n124:     if len(sys.argv) != 3:\n125:         sys.exit(usage)\n126:     taxa = read_taxa_file(sys.argv[2])\n127:     generate_merge_table(sys.stdout, taxa)\n128: else:\n129:     sys.exit(usage)\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\n# HELPER SCRIPT TO MANAGE TAXA\n#\n# Uberon bridging and compositing processes require a bit of information\n# about the taxa that are involved. To make it easier to manage those\n# informations, they are centralised in the config/taxa.yaml file.\n#\n# The main contents of the config/taxa.yaml file is a list of taxa,\n# where each taxon is represented by a structure that should look like\n# this:\n#\n# ---8<-----\n# taxon_id: NCBITaxon:1234\n# label: <human-readable suffix to append to term labels>\n# compositing:\n#   unfold_over: <list of properties to unfold tax-specific terms over\n#                (defaults to BFO:0000050, BFO:0000066)>\n#   preserve: <list of properties that should be preserved when unfolding>\n# bridging:","truncated":false,"loaded":[]},"title":"src/scripts/taxa.py","time":{"start":1778975296620,"end":1778975296638}},"id":"prt_e3330cc670018Ro6YwwrxZ8OEX","sessionID":"ses_1cccff35bffef2xqhPYhjIHD90","messageID":"msg_e3330bc10001eb7BWFwoLkX2m5"}}
{"type":"tool_use","timestamp":1778975296663,"sessionID":"ses_1cccff35bffef2xqhPYhjIHD90","part":{"type":"tool","tool":"read","callID":"call_vWJRDL5ZPvLlNkhFSDAaddRy","state":{"status":"completed","input":{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/docs/bridges.md","offset":200,"limit":140},"output":"<path>/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/docs/bridges.md</path>\n<type>file</type>\n<content>\n200: This section is a (very) brief overview of the pipeline that generates\n201: the bridge files.\n202: \n203: The pipeline may be triggered by invoking the Make target\n204: `refresh-bridges` (whilst in the in `src/ontology` directory, where the\n205: Makefile is located). Here is what happens then:\n206: \n207: 1. Production of a SSSOM mapping set from the Uberon cross-references.\n208:    Cross-references are extracted directly from the Uberon `-edit` file\n209:    and turned into a SSSOM mapping set. This takes care of all the\n210:    mappings with the foreign ontologies for which Uberon is the source\n211:    of truth.\n212: 2. Production of a SSSOM mapping sets from ontologies that maintain\n213:    their own mappings as cross-references. The foreign ontologies are\n214:    downloaded and their cross-references are extracted in the same way\n215:    as the Uberon cross-references are. Note that currently there is no\n216:    such ontology.\n217: 3. Fetching of externally maintained mapping sets. For ontologies that\n218:    maintain their own mappings and provide a SSSOM mapping set directly,\n219:    we fetch the mapping set as it is. This currently concerns FBbt and\n220:    CL (the CL set brings with it the mappings between CL and all the\n221:    species-specific ontologies).\n222: 4. Merging of all the mapping sets. We merge the SSSOM mapping set that\n223:    was derived from the Uberon cross-references (step 1), the sets that\n224:    were derived from the cross-references of foreign ontologies\n225:    (step 2), and the sets that we obtained directly from foreign\n226:    ontologies (step 3).\n227: 5. Production of the bridges. We apply a large SSSOM/T-OWL ruleset\n228:    (derived from `bridge/bridges.rules`, see below for more details about\n229:    that ruleset) to produce bridging axioms from the mappings in the\n230:    combined mapping set obtained at step 4.\n231: 6. Dispatching into individual bridges. The axioms produced at step 5\n232:    are written to different bridges depending on the ontologies they are\n233:    bridging (e.g., an axiom that bridges a Uberon term and a ZFA term\n234:    will be written to the `uberon-bridge-to-zfa.owl` bridge file).\n235: 7. Fetching the custom bridges. Independently of all the previous steps,\n236:    the “custom” bridges are fetched from their upstream source.\n237: \n238: Note that steps 2, 3, and 7 only happen when the Make variable `IMP` is\n239: set to `true` (which is always the case when the pipeline is explicitly\n240: triggered with `make refresh-bridges`). When `IMP` is set to `false`,\n241: the bridge files are re-generated using only locally available resources\n242: previously committed to the repository.\n243: \n244: Uberon maintainers should run `make refresh-bridges` periodically to\n245: refresh external resources and commit refreshed versions to the\n246: repository, similarly to what is needed to refresh the imports.\n247: \n248: ### The bridging SSSOM/T-OWL ruleset\n249: \n250: The SSSOM/T-OWL ruleset mentioned in step 5 above is where most of the\n251: logic for the production of bridge files is described. For a general\n252: overview of the SSSOM/T-OWL language, please refer to the corresponding\n253: [documentation](https://incenp.org/dvlpt/sssom-java/sssom-ext/sssomt-owl.html)\n254: in the SSSOM-Java project.\n255: \n256: Because the ruleset is highly repetitive, with many almost identical\n257: rules for every species we need to bridge to, it is partially\n258: automatically generated from a taxa list found in the `config/taxa.yaml`\n259: file.\n260: \n261: An entry in the taxa list should look like the following:\n262: \n263: ```yaml\n264: taxon_id: NCBITaxon:7227\n265: label: D melanogaster\n266: bridging:\n267:   - prefix: FBbt\n268:     namespace: http://purl.obolibrary.org/obo/FBbt_\n269:     label: D melanogaster\n270:     name: fbbt\n271:   - prefix: FBdv\n272:     namespace: http://purl.obolibrary.org/obo/FBdv_\n273:     label: D melanogaster\n274:     name: fbdv\n275: ```\n276: \n277: * `taxon_id` is the NCBI taxonomic identifier for the species we are\n278:   bridging to.\n279: * `label` is the human-readable name of the taxon.\n280: * `bridging` is the list of bridges (there may be more than one, as in\n281:   example above) for that taxon.\n282: \n283: Each bridge is in turn described by:\n284: \n285: * the `prefix` identifying the terms the bridge should include;\n286: * the corresponding `namespace` the prefix expands to;\n287: * the human-readable `label` of the taxon that should be appended to the\n288:   label of each bridged term to form the “OBO Foundry Unique Label”;\n289: * the `name` of the bridge, which will be used to form the name of the\n290:   bridge file (`uberon-bridge-to-NAME.owl`).\n291: \n292: So, the example above states that `FBbt:*` terms (terms in the\n293: `http://purl.obolibrary.org/obo/FBbt_` namespace) mapped to Uberon terms\n294: should yield bridging axioms in a `uberon-bridge-to-fbbt.owl` bridge\n295: file, while `FBdv:*` terms (in the\n296: `http://purl.obolibrary.org/obo/FBdv_` namespace) mapped to Uberon terms\n297: should yield bridging axioms in a `uberon-bridge-to-fbdv.owl` file. In\n298: all cases, the bridged terms should be annotated with a “OBO Foundry\n299: Unique Label” annotation of the form “Uberon label (D melanogaster)”.\n300: \n301: Note that:\n302: \n303: * If a bridge does not have an explicit `namespace`, a default namespace\n304:   of `http://purl.obolibrary.org/obo/PREFIX_` is used.\n305: * If a bridge does not have an explicit `label`, the top-level `label`\n306:   for the taxon is used.\n307: * If a bridge does not have an explicit `name`, the default name is the\n308:   lowercase version of the prefix.\n309: \n310: Those default rules mean that the example above can be written more\n311: simply as:\n312: \n313: ```yaml\n314: taxon_id: NCBITaxon:7227\n315: label: D melanogaster\n316: bridging:\n317:   - prefix: FBbt\n318:   - prefix: FBdv\n319: ```\n\n(End of file - total 319 lines)\n</content>","metadata":{"preview":"This section is a (very) brief overview of the pipeline that generates\nthe bridge files.\n\nThe pipeline may be triggered by invoking the Make target\n`refresh-bridges` (whilst in the in `src/ontology` directory, where the\nMakefile is located). Here is what happens then:\n\n1. Production of a SSSOM mapping set from the Uberon cross-references.\n   Cross-references are extracted directly from the Uberon `-edit` file\n   and turned into a SSSOM mapping set. This takes care of all the\n   mappings with the foreign ontologies for which Uberon is the source\n   of truth.\n2. Production of a SSSOM mapping sets from ontologies that maintain\n   their own mappings as cross-references. The foreign ontologies are\n   downloaded and their cross-references are extracted in the same way\n   as the Uberon cross-references are. Note that currently there is no\n   such ontology.\n3. Fetching of externally maintained mapping sets. For ontologies that\n   maintain their own mappings and provide a SSSOM mapping set directly,\n   we fetch the mapping set as it is. This currently concerns FBbt and","truncated":false,"loaded":[]},"title":"docs/bridges.md","time":{"start":1778975296629,"end":1778975296660}},"id":"prt_e3330cc71001Weg7r5NnhMBHlr","sessionID":"ses_1cccff35bffef2xqhPYhjIHD90","messageID":"msg_e3330bc10001eb7BWFwoLkX2m5"}}
{"type":"tool_use","timestamp":1778975296678,"sessionID":"ses_1cccff35bffef2xqhPYhjIHD90","part":{"type":"tool","tool":"read","callID":"call_2iiNodN9N71MhB3iujLwe6G5","state":{"status":"completed","input":{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/uberon.Makefile","offset":1160,"limit":200},"output":"<path>/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/uberon.Makefile</path>\n<type>file</type>\n<content>\n1160: \t$(ROBOT) annotate -i $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) -o $@\n1161: composite-vertebrate.owl: $(TMPDIR)/composite-vertebrate.owl\n1162: \t$(ROBOT) annotate -i $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) -o $@\n1163: composite-lifestages.owl: $(TMPDIR)/composite-lifestages.owl\n1164: \t$(ROBOT) annotate -i $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) -o $@\n1165: \n1166: # XAO contains both anatomical terms and life stage terms. To build\n1167: # collected-lifestages (step 1c above), we need to extract the life stage\n1168: # terms only (all descendants of XAO:1000000, \"Xenopus developmental stage\"),\n1169: # and bridge them with corresponding Uberon terms.\n1170: $(TMPDIR)/xao-ls-bridged.owl: $(IMPORTDIR)/local-xao.owl \\\n1171: \t\t\t\t       $(MAPPINGDIR)/uberon-local.sssom.tsv \\\n1172: \t\t\t\t       | all_robot_plugins\n1173: \t$(ROBOT) extract -i $< --method MIREOT --branch-from-term XAO:1000000 \\\n1174: \t\t sssom:inject --sssom $(MAPPINGDIR)/uberon-local.sssom.tsv \\\n1175: \t\t              --ruleset $(BRIDGEDIR)/bridge-xao-ls.rules \\\n1176: \t\t              -o $@\n1177: \n1178: # SSLSO contains the entirety of HsapDv, but to construct collected-human,\n1179: # we specifically need the HsapDv terms only, so we extract them from SSLSO.\n1180: # This is also needed to construct the life-stages-mammal subset.\n1181: $(TMPDIR)/hsapdv.owl: $(IMPORTDIR)/local-sslso.owl\n1182: \t$(ROBOT) extract -i $< --method MIREOT --branch-from-term HsapDv:0000000 -o $@\n1183: \n1184: # Ditto for MmusDv.\n1185: $(TMPDIR)/mmusdv.owl: $(IMPORTDIR)/local-sslso.owl\n1186: \t$(ROBOT) extract -i $< --method MIREOT --branch-from-term MmusDv:0000000 -o $@\n1187: \n1188: \n1189: # Some special products derived from the products generated above\n1190: # ----------------------------------------\n1191: BASICRELS = BFO:0000050 RO:0002202 immediate_transformation_of transformation_of\n1192: \n1193: composite-metazoan-basic.owl: composite-metazoan.owl\n1194: \t$(OWLTOOLS) $< --extract-mingraph --remove-axiom-annotations \\\n1195: \t\t    --make-subset-by-properties -f $(BASICRELS) \\\n1196: \t\t    -o -f obo --no-check $@.tmp && \\\n1197: \tgrep -v '^owl-axioms:' $@.tmp > $@ && \\\n1198: \t$(ROBOT) annotate -i $@ --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n1199: \t\t convert --check false -f owl -o $@.tmp && \\\n1200: \tmv $@.tmp $@\n1201: \n1202: composite-vertebrate-basic.owl: composite-vertebrate.owl\n1203: \t$(OWLTOOLS) $< --extract-mingraph --remove-axiom-annotations \\\n1204: \t\t    --make-subset-by-properties -f $(BASICRELS) \\\n1205: \t\t    -o -f obo --no-check $@.tmp && \\\n1206: \tgrep -v '^owl-axioms:' $@.tmp > $@ && \\\n1207: \t$(ROBOT) annotate -i $@ --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n1208: \t\t convert --check false -f owl -o $@.tmp && \\\n1209: \tmv $@.tmp $@\n1210: \n1211: \n1212: # Helper commands for composite-* stuff\n1213: # ----------------------------------------\n1214: \n1215: # Create a diff with the latest released version\n1216: $(TMPDIR)/composite-metazoan-last-release.owl:\n1217: \twget https://github.com/obophenotype/uberon/releases/latest/download/composite-metazoan.owl -O $@\n1218: \n1219: reports/release-diff-composite.txt: $(TMPDIR)/composite-metazoan-last-release.owl composite-metazoan.owl\n1220: \t$(ROBOT) diff --left composite-metazoan-last-release.owl --right composite-metazoan.owl -o $@\n1221: \n1222: .PHONY: composite-diff\n1223: composite-diff: reports/release-diff-composite.txt\n1224: \n1225: \n1226: # Saves someone the hassle of typing 'make composite-metazoan.obo composite-vertebrate.obo'\n1227: composites: composite-metazoan.obo composite-vertebrate.obo\n1228: \n1229: \n1230: # ----------------------------------------\n1231: # SSSOM MAPPINGS\n1232: # ----------------------------------------\n1233: \n1234: # Uberon's \"local\" mapping set (extracted from cross-references).\n1235: # Several cross-references are using OBO prefixes that are unknown to\n1236: # ROBOT and not declared in Uberon/CL, so they need to be explicitly\n1237: # declared here (otherwise xref-extract would ignore them).\n1238: $(MAPPINGDIR)/uberon-local.sssom.tsv: $(SRC) | all_robot_plugins\n1239: \t$(ROBOT) merge -i $< --collapse-import-closure false \\\n1240: \t\t sssom:xref-extract --mapping-file $@ -v --drop-duplicates \\\n1241: \t\t                    --prefix 'DHBA:  https://purl.brain-bican.org/ontology/dhbao/DHBA_' \\\n1242: \t\t                    --prefix 'EFO:   http://purl.obolibrary.org/obo/EFO_'   \\\n1243: \t\t                    --prefix 'HBA:   https://purl.brain-bican.org/ontology/hbao/HBA_' \\\n1244: \t\t                    --prefix 'KUPO:  http://purl.obolibrary.org/obo/KUPO_'  \\\n1245: \t\t                    --prefix 'OGES:  http://purl.obolibrary.org/obo/OGES_'  \\\n1246: \t\t                    --prefix 'PBA:   https://purl.brain-bican.org/ontology/pbao/PBA_'   \\\n1247: \t\t                    --prefix 'SCTID: http://purl.obolibrary.org/obo/SCTID_' \\\n1248: \t\t                    --prefix 'FMA:   http://purl.org/sig/ont/fma/fma' \\\n1249: \t> $(REPORTDIR)/uberon-xrefs-extraction.txt\n1250: \n1251: # Uberon's \"meta\" mapping set, containing all mappings between Uberon\n1252: # and foreign ontologies, regardless of where they are maintained. Made\n1253: # by compiling the \"local\" set above with the remote sets obtained below.\n1254: $(MAPPINGDIR)/uberon.sssom.tsv: $(MAPPINGDIR)/uberon-local.sssom.tsv \\\n1255: \t\t\t\t$(MAPPINGDIR)/fbbt.sssom.tsv \\\n1256: \t\t\t\t$(MAPPINGDIR)/sslso.sssom.tsv\n1257: \tsssom-cli $(foreach src, $^, -i $(src)) \\\n1258: \t\t  --prefix-map-from-input \\\n1259: \t\t  --rule 'object==UBERON:* -> invert()' \\\n1260: \t\t  --rule 'subject==UBERON:* -> include()' \\\n1261: \t\t  --output $@\n1262: \n1263: # Remote mapping sets\n1264: # -------------------\n1265: \n1266: # The following providers publish their own mapping sets.\n1267: EXTERNAL_SSSOM_PROVIDERS = fbbt cl sslso biomappings\n1268: \n1269: # All the sets coming from the above ontologies.\n1270: EXTERNAL_SSSOM_SETS = $(foreach provider, $(EXTERNAL_SSSOM_PROVIDERS), $(MAPPINGDIR)/$(provider).sssom.tsv)\n1271: \n1272: # We only refresh external resources under MIR=true\n1273: ifeq ($(strip $(MIR)),true)\n1274: \n1275: # FBbt mapping set. We filter it to only keep UBERON-related mappings\n1276: # (CL-related mappings are already bundled with the CL set).\n1277: $(MAPPINGDIR)/fbbt.sssom.tsv: .FORCE\n1278: \twget \"http://purl.obolibrary.org/obo/fbbt/fbbt.sssom.tsv\" -O - | \\\n1279: \t\tsssom-cli --prefix-map-from-input \\\n1280: \t\t          --include 'object==UBERON:*' \\\n1281: \t\t          --update-from-ontology=$(SRC):object,label,existence \\\n1282: \t\t          --output $@\n1283: \n1284: # CL mapping set. We simply fetch it as it is from CL. It already\n1285: # contains all mappings related to CL (including the FBbt and ZFA ones).\n1286: $(MAPPINGDIR)/cl.sssom.tsv: .FORCE\n1287: \twget \"http://purl.obolibrary.org/obo/cl/cl.sssom.tsv\" -O $@\n1288: \n1289: # SSLSO (life stages) mapping set. We simply fetch it as it is.\n1290: $(MAPPINGDIR)/sslso.sssom.tsv: .FORCE\n1291: \twget \"https://github.com/obophenotype/developmental-stage-ontologies/releases/latest/download/life-stages.sssom.tsv\" -O $@\n1292: \n1293: # Biomappings mapping set. Nominally a simple mirror, but we need a\n1294: # custom rule for two reasons:\n1295: # - the set is provided with the metadata in a separate file, which the\n1296: #   ODK mirroring code does not support;\n1297: # - we want to filter out anything anything that has nothing to do with\n1298: #   Uberon to keep the file to a reasonable size.\n1299: $(MAPPINGDIR)/biomappings.sssom.tsv: $(TMPDIR)/biomappings.sssom.tsv \\\n1300: \t\t\t\t     $(TMPDIR)/biomappings.sssom.yml\n1301: \tsssom-cli --input $< --prefix 'UBERON=http://purl.obolibrary.org/obo/UBERON_' \\\n1302: \t\t  --rule '!(subject==UBERON:* || object==UBERON:*) -> stop()' \\\n1303: \t\t  --rule 'object==UBERON:* -> invert()' \\\n1304: \t\t  --include-all \\\n1305: \t\t  --update-from-ontology=$(SRC):subject,label,existence | \\\n1306: \tsssom-cli --mangle-iris obo --output $@\n1307: \n1308: $(TMPDIR)/biomappings.sssom.tsv:\n1309: \twget -O $@ https://w3id.org/biopragmatics/biomappings/sssom/biomappings.sssom.tsv\n1310: \n1311: $(TMPDIR)/biomappings.sssom.yml:\n1312: \twget -O $@ https://w3id.org/biopragmatics/biomappings/sssom/biomappings.sssom.yml\n1313: \n1314: endif\n1315: \n1316: \n1317: # ----------------------------------------\n1318: # BRIDGES\n1319: # ----------------------------------------\n1320: ifeq ($(BRI),true)\n1321: \n1322: # Those bridges are generated separately (see below).\n1323: EXTERN_BRIDGES = $(BRIDGEDIR)/uberon-bridge-to-mba.owl \\\n1324: \t\t $(BRIDGEDIR)/uberon-bridge-to-dmba.owl\n1325: \n1326: # 1. Prepare the ruleset file.\n1327: # The ruleset file is maintained with the help of the Python script\n1328: # to automatically insert the taxon-specific rules.\n1329: $(TMPDIR)/bridges.rules: $(SCRIPTSDIR)/taxa.py config/taxa.yaml $(BRIDGEDIR)/bridges.rules\n1330: \tpython3 $(SCRIPTSDIR)/taxa.py make-rules config/taxa.yaml $(BRIDGEDIR)/bridges.rules > $@\n1331: \n1332: # 2. Generate the bridges from the \"meta\" mapping set and the CL set.\n1333: # Note that merging CL here is not strictly necessary, but doing so\n1334: # allows sssom-inject to filter out any mapping with an inexistent or\n1335: # obsolete Uberon/CL class.\n1336: $(TMPDIR)/bridges: $(SRC) $(IMPORTDIR)/local-cl.owl \\\n1337: \t\t   $(MAPPINGDIR)/uberon.sssom.tsv $(MAPPINGDIR)/cl.sssom.tsv \\\n1338: \t\t   $(TMPDIR)/bridges.rules $(BRIDGEDIR)/bridges.dispatch \\\n1339: \t\t   $(EXTERN_BRIDGES) | all_robot_plugins\n1340: \t$(ROBOT) merge -i $(SRC) -i $(IMPORTDIR)/local-cl.owl \\\n1341: \t\t sssom:inject --sssom $(MAPPINGDIR)/uberon.sssom.tsv \\\n1342: \t\t              --sssom $(MAPPINGDIR)/cl.sssom.tsv \\\n1343: \t\t              --ruleset $(TMPDIR)/bridges.rules \\\n1344: \t\t              --exclude-rule xrefs \\\n1345: \t\t              --dispatch-table $(BRIDGEDIR)/bridges.dispatch && \\\n1346: \ttouch $@\n1347: \n1348: # The above step creates RDF/XML bridges, turn them to OBO.\n1349: # FIXME: Is this really necessary? Previously the OBO files were an\n1350: # intermediate towards the final bridge files in OWL, but now we can\n1351: # generate bridge files in OWL (or any format we want) directly, so\n1352: # I don't think we need to carry over OBO files.\n1353: $(BRIDGEDIR)/%.obo: $(BRIDGEDIR)/%.owl\n1354: \t$(ROBOT) convert -i $< --check false -f obo -o $@\n1355: \n1356: \n1357: # Custom bridges\n1358: # ----------------------------------------\n1359: # All bridges that are not generated from SSSOM sets.\n\n(Showing lines 1160-1359 of 1680. Use offset=1360 to continue.)\n</content>","metadata":{"preview":"\t$(ROBOT) annotate -i $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) -o $@\ncomposite-vertebrate.owl: $(TMPDIR)/composite-vertebrate.owl\n\t$(ROBOT) annotate -i $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) -o $@\ncomposite-lifestages.owl: $(TMPDIR)/composite-lifestages.owl\n\t$(ROBOT) annotate -i $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) -o $@\n\n# XAO contains both anatomical terms and life stage terms. To build\n# collected-lifestages (step 1c above), we need to extract the life stage\n# terms only (all descendants of XAO:1000000, \"Xenopus developmental stage\"),\n# and bridge them with corresponding Uberon terms.\n$(TMPDIR)/xao-ls-bridged.owl: $(IMPORTDIR)/local-xao.owl \\\n\t\t\t\t       $(MAPPINGDIR)/uberon-local.sssom.tsv \\\n\t\t\t\t       | all_robot_plugins\n\t$(ROBOT) extract -i $< --method MIREOT --branch-from-term XAO:1000000 \\\n\t\t sssom:inject --sssom $(MAPPINGDIR)/uberon-local.sssom.tsv \\\n\t\t              --ruleset $(BRIDGEDIR)/bridge-xao-ls.rules \\\n\t\t              -o $@\n\n# SSLSO contains the entirety of HsapDv, but to construct collected-human,\n# we specifically need the HsapDv terms only, so we extract them from SSLSO.","truncated":true,"loaded":[]},"title":"src/ontology/uberon.Makefile","time":{"start":1778975296653,"end":1778975296676}},"id":"prt_e3330cc89001tjhj4ioTwah509","sessionID":"ses_1cccff35bffef2xqhPYhjIHD90","messageID":"msg_e3330bc10001eb7BWFwoLkX2m5"}}
