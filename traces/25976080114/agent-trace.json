XAO term below \"Xenopus developmental stage\" (XAO:1000000).\n subject==UBERON:* predicate==semapv:crossSpeciesExactMatch is_a(%{object_id}, XAO:1000000) -> {\n     annotate(%{object_id}, IAO:0000589, \"%{subject_label} (xenopus)\");\n-    create_axiom(\"%object_id EquivalentTo: %subject_id and (BFO:0000066 some NCBITaxon:8353)\");\n+    create_axiom(\"%object_id EquivalentTo: %subject_id and (RO:0002162 some NCBITaxon:8353)\");\n }\n","additions":4,"deletions":2},{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/scripts/make-bridge-ontologies-from-xrefs.pl","relativePath":"src/scripts/make-bridge-ontologies-from-xrefs.pl","type":"update","patch":"Index: /__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/scripts/make-bridge-ontologies-from-xrefs.pl\n===================================================================\n--- /__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/scripts/make-bridge-ontologies-from-xrefs.pl\n+++ /__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/scripts/make-bridge-ontologies-from-xrefs.pl\n@@ -83,9 +83,9 @@\n             }\n             elsif ($t eq 'gd') {\n                 print $fh \"intersection_of: $id ! $n\\n\";\n                 if (exists($lsxrefs{$x})) {\n-                    $rel = \"occurs_in\";\n+                    $rel = \"in_taxon\";\n                 }\n                 print $fh \"intersection_of: $rel $filler\\n\";\n             }\n             else {\n@@ -129,8 +129,11 @@\n print $fh \"xref: RO:0002225\\n\\n\";\n print $fh \"[Typedef]\\n\";\n print $fh \"id: occurs_in\\n\";\n print $fh \"xref: BFO:0000066\\n\\n\";\n+print $fh \"[Typedef]\\n\";\n+print $fh \"id: in_taxon\\n\";\n+print $fh \"xref: RO:0002162\\n\\n\";\n \n open(F,\"ftr.obo\");\n while(<F>) {\n     print $fh $_;\n","additions":4,"deletions":1},{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/make-bridge-ontologies-from-xrefs.pl","relativePath":"src/ontology/make-bridge-ontologies-from-xrefs.pl","type":"update",