ron/docs/Inter-ontology-disjointness-Design-Pattern\" xsd:anyURI\nproperty_value: seeAlso https://github.com/obophenotype/uberon/issues/55\nidspace: NIF_GrossAnatomy http://ontology.neuinfo.org/NIF/BiomaterialEntities/NIF-GrossAnatomy.owl#\n\n[Term]\nid: UBERON:0004757 ! rectal salt gland\ndisjoint_from: FMA:15724 ! Rectal gland\n\n[Term]\nid: UBERON:0001736 ! submandibular gland\ndisjoint_from: HAO:0000514 ! maxillary gland\n\n[Term]\nid: UBERON:0005346 ! cerebellum vermis lobule VIIb\ndisjoint_from: FMA:75430 ! Tuber","truncated":false,"loaded":[]},"title":"src/ontology/components/external-disjoints.obo","time":{"start":1778976712179,"end":1778976712200}},"id":"prt_e334665e6001HgRJGjLJcyUbbE","sessionID":"ses_1ccb9db97ffeChlqt6Zzc4r0d3","messageID":"msg_e33464d4000170E40oMFCxfOar"}}
