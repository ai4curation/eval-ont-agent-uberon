 elif [ -f \"$HOME/Library/Application Support/ontology-development-kit/github/token\" ]; then\n49:     GH_TOKEN=$(cat \"$HOME/Library/Application Support/ontology-development-kit/github/token\")\n50: fi\n51: \n52: # SSH agent socket\n53: # On macOS, we cannot use $SSH_AUTH_SOCK directly,\n54: # we need to use a \"magic\" socket instead.\n55: case \"$(uname)\" in\n56: Darwin)\n57:     ODK_SSH_AUTH_SOCKET=/run/host-services/ssh-auth.sock\n58:     ;;\n59: *)\n60:     ODK_SSH_AUTH_SOCKET=$SSH_AUTH_SOCK\n61:     ;;\n62: esac\n63: ODK_SSH_BIND=\n64: if [ -n \"$ODK_SSH_AUTH_SOCKET\" ]; then\n65:     ODK_SSH_BIND=\",$ODK_SSH_AUTH_SOCKET:/run/host-services/ssh-auth.sock\"\n66: fi\n67: \n68: ODK_IMAGE=${ODK_IMAGE:-odkfull}\n69: TAG_IN_IMAGE=$(echo $ODK_IMAGE | awk -F':' '{ print $2 }')\n70: if [ -n \"$TAG_IN_IMAGE\" ]; then\n71:   # Override ODK_TAG env var if IMAGE already includes a tag\n72:   ODK_TAG=$TAG_IN_IMAGE\n73:   ODK_IMAGE=$(echo $ODK_IMAGE | awk -F':' '{ print $1 }')\n74: fi\n75: ODK_TAG=${ODK_TAG:-latest}\n76: \n77: ODK_JAVA_OPTS=${ODK_JAVA_OPTS:--Xmx20G}\n78: \n79: ODK_DEBUG=${ODK_DEBUG:-no}\n80: \n81: ODK_USER_ID=${ODK_USER_ID:-$(id -u)}\n82: ODK_GROUP_ID=${ODK_GROUP_ID:-$(id -g)}\n83: \n84: # Convert OWLAPI_* environment variables to the OWLAPI as Java options\n85: # See http://owlcs.github.io/owlapi/apidocs_4/org/semanticweb/owlapi/model/parameters/ConfigurationOptions.html\n86: # for a list of allowed options\n87: OWLAPI_OPTIONS_NAMESPACE=org.semanticweb.owlapi.model.parameters.ConfigurationOptions\n88: for owlapi_var in $(env | sed -n s/^OWLAPI_//p) ; do\n89:     ODK_JAVA_OPTS=\"$ODK_JAVA_OPTS -D$OWLAPI_OPTIONS_NAMESPACE.${owlapi_var%=*}=${owlapi_var#*=}\"\n90: done\n91: \n92: # Proxy settings for Java applications\n93: [ -z \"$HTTP_PROXY\" ] && [ -n \"$http_proxy\" ] && HTTP_PROXY=$http_proxy\n94: if [ -n \"$HTTP_PROXY\" ]; then\n95:     proxy_host=$(echo $HTTP_PROXY | sed -E 's,^https?://,,; s,:[0-9]+$,,')\n96:     proxy_port=$(echo $HTTP_PROXY | sed -E 's,^.*:([0-9]+)$,\\1,')\n97:     ODK_JAVA_OPTS=\"$ODK_JAVA_OPTS -Dhttp.proxyHost=$proxy_host\"\n98:     [ \"$proxy_port\" != \"$proxy_host\" ] && ODK_JAVA_OPTS=\"$ODK_JAVA_OPTS -Dhttp.proxyPort=$proxy_port\"\n99: fi\n100: [ -z \"$HTTPS_PROXY\" ] && [ -n \"$https_proxy\" ] && HTTPS_PROXY=$https_proxy\n101: if [ -n \"$HTTPS_PROXY\" ]; then\n102:     proxy_host=$(echo $HTTPS_PROXY | sed -E 's,^https?://,,; s,:[0-9]+$,,')\n103:     proxy_port=$(echo $HTTPS_PROXY | sed -E 's,^.*:([0-9]+)$,\\1,')\n104:     ODK_JAVA_OPTS=\"$ODK_JAVA_OPTS -Dhttps.proxyHost=$proxy_host\"\n105:     [ \"$proxy_port\" != \"$proxy_host\" ] && ODK_JAVA_OPTS=\"$ODK_JAVA_OPTS -Dhttps.proxyPort=$proxy_port\"\n106: fi\n107: [ -z \"$NO_PROXY\" ] && [ -n \"$no_proxy\" ] && NO_PROXY=$no_proxy\n108: if [ -n \"$NO_PROXY\" ] ; then\n109:     no_proxy_hosts=$(echo $NO_PROXY | tr ',' '|')\n110:     ODK_JAVA_OPTS=\"$ODK_JAVA_OPTS -Dhttp.nonProxyHosts=$no_proxy_hosts\"\n111: fi\n112: \n113: TIMECMD=\n114: if [ x$ODK_DEBUG = xyes ]; then\n115:     # If you wish to change the format string, take care of using\n116:     # non-breaking spaces (U+00A0) instead of normal spaces, to\n117:     # prevent the shell from tokenizing the format string.\n118:     echo \"Running obolibrary/${ODK_IMAGE}:${ODK_TAG} with '${ODK_JAVA_OPTS}' as options for ROBOT and other Java-based pipeline steps.\"\n119:     TIMECMD=\"/usr/bin/time -f ### DEBUG STATS ###\\nElapsed time: %E\\nPeak memory: %M kb\"\n120: fi\n121: rm -f tmp/debug.log\n122: \n123: VOLUME_BIND=$PWD/../../:/work$ODK_SSH_BIND\n124: WORK_DIR=/work/src/ontology\n125: \n126: # Support for OAK cache sharing\n127: if [ -n \"$ODK_SHARE_OAK_CACHE\" ]; then\n128:     case \"$ODK_SHARE_OAK_CACHE\" in\n129:     user)\n130:         # We assume the cache is in its default location; if it is not,\n131:         # ODK_SHARE_OAK_CACHE must point to the actual location.\n132:         ODK_SHARE_OAK_CACHE=\"$HOME/.data/oaklib\"\n133:         ;;\n134:     repo)\n135:         ODK_SHARE_OAK_CACHE=\"$PWD/tmp/oaklib\"\n136:         ;;\n137:     esac\n138:     [ $ODK_USER_ID -eq 0 ] && OAK_DEST=/root/.data/oaklib || OAK_DEST=/home/odkuser/.data/oaklib\n139:     VOLUME_BIND=\"$VOLUME_BIND,$ODK_SHARE_OAK_CACHE:$OAK_DEST\"\n140: fi\n141: \n142: if [ -n \"$ODK_BINDS\" ]; then\n143:     VOLUME_BIND=\"$VOLUME_BIND,$ODK_BINDS\"\n144: fi\n145: \n146: if [ -n \"$USE_SINGULARITY\" ]; then\n147:     \n148:     singularity exec --cleanenv $ODK_SINGULARITY_OPTIONS \\\n149:         --env \"ROBOT_JAVA_ARGS=$ODK_JAVA_OPTS,JAVA_OPTS=$ODK_JAVA_OPTS,SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock,ODK_USER_ID=$ODK_USER_ID,ODK_GROUP_ID=$ODK_GROUP_ID,ODK_DEBUG=$ODK_DEBUG\" \\\n150:         --bind $VOLUME_BIND \\\n151:         -W $WORK_DIR \\\n152:         docker://obolibrary/$ODK_IMAGE:$ODK_TAG $TIMECMD \"$@\"\n153: else\n154:     BIND_OPTIONS=\"-v $(echo $VOLUME_BIND | sed 's/,/ -v /g')\"\n155:     docker run $ODK_DOCKER_OPTIONS $BIND_OPTIONS -w $WORK_DIR \\\n156:         -e ROBOT_JAVA_ARGS=\"$ODK_JAVA_OPTS\" -e JAVA_OPTS=\"$ODK_JAVA_OPTS\" -e SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock -e ODK_USER_ID=$ODK_USER_ID -e ODK_GROUP_ID=$ODK_GROUP_ID -e ODK_DEBUG=$ODK_DEBUG \\\n157:         --rm -ti obolibrary/$ODK_IMAGE:$ODK_TAG $TIMECMD \"$@\"\n158: fi\n159: \n160: case \"$@\" in\n161: *update_repo*|*release*)\n162:     echo \"Please remember to update your ODK image from time to time: https://oboacademy.github.io/obook/howto/odk-update/.\"\n163:     ;;\n164: esac\n\n(End of file - total 164 lines)\n</content>","metadata":{"preview":"#!/bin/sh\n# Wrapper script for docker.\n#\n# This is used primarily for wrapping the GNU Make workflow.\n# Instead of typing \"make TARGET\", type \"./run.sh make TARGET\".\n# This will run the make workflow within a docker container.\n#\n# The assumption is that you are working in the src/ontology folder;\n# we therefore map the whole repo (../..) to a docker volume.\n#\n# To use singularity instead of docker, please issue\n# export USE_SINGULARI