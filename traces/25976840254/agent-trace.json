{"type":"tool_use","timestamp":1778977742246,"sessionID":"ses_1ccaac4b7ffeFdfInqP9xrJ9GR","part":{"type":"tool","tool":"read","callID":"call_qMkigixJJVV4LbntWlebcKu5","state":{"status":"completed","input":{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/bridge/bridges.rules","offset":1,"limit":80},"output":"<path>/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/bridge/bridges.rules</path>\n<type>file</type>\n<content>\n1: # SSSOM is OBO-agnostic and doesn't know about the implicit OBO prefix\n2: # rule (PFX -> http://purl.obolibrary.org/obo/PFX_); *all* prefixes must\n3: # be explicitly declared.\n4: prefix AEO:       <http://purl.obolibrary.org/obo/AEO_>\n5: prefix BFO:       <http://purl.obolibrary.org/obo/BFO_>\n6: prefix BSPO:      <http://purl.obolibrary.org/obo/BSPO_>\n7: prefix CARO:      <http://purl.obolibrary.org/obo/CARO_>\n8: prefix CL:        <http://purl.obolibrary.org/obo/CL_>\n9: prefix GO:        <http://purl.obolibrary.org/obo/GO_>\n10: prefix IAO:       <http://purl.obolibrary.org/obo/IAO_>\n11: prefix NCBITaxon: <http://purl.obolibrary.org/obo/NCBITaxon_>\n12: prefix NCIT:      <http://purl.obolibrary.org/obo/NCIT_>\n13: prefix OG:        <http://purl.obolibrary.org/obo/OG_>\n14: prefix OGES:      <http://purl.obolibrary.org/obo/OGES_>\n15: prefix OIO:       <http://www.geneontology.org/formats/oboInOwl#>\n16: prefix RO:        <http://purl.obolibrary.org/obo/RO_>\n17: prefix SCTID:     <http://purl.obolibrary.org/obo/SCTID_>\n18: prefix UBERON:    <http://purl.obolibrary.org/obo/UBERON_>\n19: %INSERT-TAX-SPECIFIC-PREFIXES\n20: \n21: # Uberon may not contain declarations for all the taxa we bridge to, so\n22: # to be on the safe side we declare all of them preventively.\n23: %INSERT-TAX-SPECIFIC-DIRECTIVES\n24: \n25: # The relation to use in the existential restrictions between Uberon/CL\n26: # terms and their taxon-specific equivalents: part_of (BFO:0000050) for\n27: # most cases, except for life stage terms where we use occurs_in\n28: # (BFO:0000066) instead.\n29: set_var(\"TAXREL\", BFO:0000050);\n30: is_a(%{object_id}, UBERON:0000104) -> set_var(\"TAXREL\", BFO:0000066);\n31: is_a(%{object_id}, UBERON:0000105) -> set_var(\"TAXREL\", BFO:0000066);\n32: \n33: # Make sure UBERON and CL classes are on the object side.\n34: subject==UBERON:* || subject==CL:* -> invert();\n35: \n36: # Ignore any mapping to something else than UBERON or CL.\n37: !(object==UBERON:* || object==CL:*) -> stop();\n38: \n39: # Ignore any mapping to an inexistent or obsolete UBERON/CL class.\n40: !exists(%{object_id}) -> stop();\n41: \n42: # Do not allow a same foreign term to be mapped with more than one UBERON/CL class.\n43: !cardinality==*:1 -> stop();\n44: \n45: # Ignore any mapping with a predicate other than those four.\n46: !(predicate==skos:exactMatch\n47:   || predicate==skos:narrowMatch\n48:   || predicate==skos:broadMatch\n49:   || predicate==semapv:crossSpeciesExactMatch) -> stop();\n50: \n51: # Generate cross-reference annotations (for backward compatibility).\n52: [xrefs] predicate==* -> annotate(%{object_id}, OIO:hasDbXref, \"%{subject_id|short}\");\n53: \n54: # Bridging axiom-generating rules.\n55: # The highly repetitive nature of those rules stems from the fact that\n56: # we need separate rules for each foreign ontology and for both Uberon\n57: # and CL, if we want to be able to send the corresponding axioms to\n58: # separate bridge files.\n59: \n60: # Taxon-neutral bridges.\n61: [aeo-uberon] subject==AEO:* object==UBERON:* {\n62:     predicate==*               -> annotate(%{subject_id}, IAO:0000589, \"%{object_label} (AEO)\");\n63:     predicate==skos:exactMatch -> create_axiom(\"%subject_id EquivalentTo: %object_id\");\n64: }\n65: [aeo-cl] subject==AEO:* object==CL:* {\n66:     predicate==*               -> annotate(%{subject_id}, IAO:0000589, \"%{object_label} (AEO)\");\n67:     predicate==skos:exactMatch -> create_axiom(\"%subject_id EquivalentTo: %object_id\");\n68: }\n69: \n70: [bfo-uberon] subject==BFO:* object==UBERON:* {\n71:     predicate==*                -> annotate(%{subject_id}, IAO:0000589, \"%{object_label} (BFO)\");\n72:     predicate==skos:narrowMatch -> create_axiom(\"%object_id SubClassOf: %subject_id\");\n73: }\n74: [bfo-cl] subject==BFO:* object==CL:* {\n75:     predicate==*                -> annotate(%{subject_id}, IAO:0000589, \"%{object_label} (BFO)\");\n76:     predicate==skos:narrowMatch -> create_axiom(\"%object_id SubClassOf: %subject_id\");\n77: }\n78: \n79: [caro-uberon] subject==CARO:* object==UBERON:* {\n80:     predicate==*               -> annotate(%{subject_id}, IAO:0000589, \"%{object_label} (CARO)\");\n\n(Showing lines 1-80 of 125. Use offset=81 to continue.)\n</content>","metadata":{"preview":"# SSSOM is OBO-agnostic and doesn't know about the implicit OBO prefix\n# rule (PFX -> http://purl.obolibrary.org/obo/PFX_); *all* prefixes must\n# be explicitly declared.\nprefix AEO:       <http://purl.obolibrary.org/obo/AEO_>\nprefix BFO:       <http://purl.obolibrary.org/obo/BFO_>\nprefix BSPO:      <http://purl.obolibrary.org/obo/BSPO_>\nprefix CARO:      <http://purl.obolibrary.org/obo/CARO_>\nprefix CL:        <http://purl.obolibrary.org/obo/CL_>\nprefix GO:        <http://purl.obolibrary.org/obo/GO_>\nprefix IAO:       <http://purl.obolibrary.org/obo/IAO_>\nprefix NCBITaxon: <http://purl.obolibrary.org/obo/NCBITaxon_>\nprefix NCIT:      <http://purl.obolibrary.org/obo/NCIT_>\nprefix OG:        <http://purl.obolibrary.org/obo/OG_>\nprefix OGES:      <http://purl.obolibrary.org/obo/OGES_>\nprefix OIO:       <http://www.geneontology.org/formats/oboInOwl#>\nprefix RO:        <http://purl.obolibrary.org/obo/RO_>\nprefix SCTID:     <http://purl.obolibrary.org/obo/SCTID_>\nprefix UBERON:    <http://purl.obolibrary.org/obo/UBERON_>\n%INSERT-TAX-SPECIFIC-PREFIXES\n","truncated":true,"loaded":[]},"title":"src/ontology/bridge/bridges.rules","time":{"start":1778977742234,"end":1778977742244}},"id":"prt_e33561d94001PbFLoIC4rpcB5u","sessionID":"ses_1ccaac4b7ffeFdfInqP9xrJ9GR","messageID":"msg_e33560bf60015ObN9klRCU5NiT"}}
{"type":"tool_use","timestamp":1778977742275,"sessionID":"ses_1ccaac4b7ffeFdfInqP9xrJ9GR","part":{"type":"tool","tool":"read","callID":"call_wY2N0k7TryxEHpunLaDrYH70","state":{"status":"completed","input":{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/bridge/bridge-xao-ls.rules","offset":1,"limit":80},"output":"<path>/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/bridge/bridge-xao-ls.rules</path>\n<type>file</type>\n<content>\n1: # This ruleset creates a special bridge for just the life stage terms\n2: # of XAO.\n3: prefix BFO:       <http://purl.obolibrary.org/obo/BFO_>\n4: prefix NCBITaxon: <http://purl.obolibrary.org/obo/NCBITaxon_>\n5: prefix UBERON:    <http://purl.obolibrary.org/obo/UBERON_>\n6: prefix XAO:       <http://purl.obolibrary.org/obo/XAO_>\n7: \n8: declare(NCBITaxon:8353);\n9: declare(BFO:0000066, /type=\"object_property\");\n10: \n11: # Looking for any exact cross-species mapping between a Uberon term and\n12: # a XAO term below \"Xenopus developmental stage\" (XAO:1000000).\n13: subject==UBERON:* predicate==semapv:crossSpeciesExactMatch is_a(%{object_id}, XAO:1000000) -> {\n14:     annotate(%{object_id}, IAO:0000589, \"%{subject_label} (xenopus)\");\n15:     create_axiom(\"%object_id EquivalentTo: %subject_id and (BFO:0000066 some NCBITaxon:8353)\");\n16: }\n\n(End of file - total 16 lines)\n</content>","metadata":{"preview":"# This ruleset creates a special bridge for just the life stage terms\n# of XAO.\nprefix BFO:       <http://purl.obolibrary.org/obo/BFO_>\nprefix NCBITaxon: <http://purl.obolibrary.org/obo/NCBITaxon_>\nprefix UBERON:    <http://purl.obolibrary.org/obo/UBERON_>\nprefix XAO:       <http://purl.obolibrary.org/obo/XAO_>\n\ndeclare(NCBITaxon:8353);\ndeclare(BFO:0000066, /type=\"object_property\");\n\n# Looking for any exact cross-species mapping between a Uberon term and\n# a XAO term below \"Xenopus developmental stage\" (XAO:1000000).\nsubject==UBERON:* predicate==semapv:crossSpeciesExactMatch is_a(%{object_id}, XAO:1000000) -> {\n    annotate(%{object_id}, IAO:0000589, \"%{subject_label} (xenopus)\");\n    create_axiom(\"%object_id EquivalentTo: %subject_id and (BFO:0000066 some NCBITaxon:8353)\");\n}","truncated":false,"loaded":[]},"title":"src/ontology/bridge/bridge-xao-ls.rules","time":{"start":1778977742250,"end":1778977742273}},"id":"prt_e33561d9d001KhezVLuldPdNxg","sessionID":"ses_1ccaac4b7ffeFdfInqP9xrJ9GR","messageID":"msg_e33560bf60015ObN9klRCU5NiT"}}
