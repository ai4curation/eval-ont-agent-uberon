uberon/src/ontology/bridge/bridge-xao-ls.rules\n@@ -1,16 +1,16 @@\n # This ruleset creates a special bridge for just the life stage terms\n # of XAO.\n-prefix BFO:       <http://purl.obolibrary.org/obo/BFO_>\n prefix NCBITaxon: <http://purl.obolibrary.org/obo/NCBITaxon_>\n+prefix RO:        <http://purl.obolibrary.org/obo/RO_>\n prefix UBERON:    <http://purl.obolibrary.org/obo/UBERON_>\n prefix XAO:       <http://purl.obolibrary.org/obo/XAO_>\n \n declare(NCBITaxon:8353);\n-declare(BFO:0000066, /type=\"object_property\");\n+declare(RO:0002162, /type=\"object_property\");\n \n # Looking for any exact cross-species mapping between a Uberon term and\n # a XAO term below \"Xenopus developmental stage\" (XAO:1000000).\n subject==UBERON:* predicate==semapv:crossSpeciesExactMatch is_a(%{object_id}, XAO:1000000) -> {\n     annotate(%{object_id}, IAO:0000589, \"%{subject_label} (xenopus)\");\n-    create_axiom(\"%object_id EquivalentTo: %subject_id and (BFO:0000066 some NCBITaxon:8353)\");\n+    create_axiom(\"%object_id EquivalentTo: %subject_id and (RO:0002162 some NCBITaxon:8353)\");\n }\n","additions":3,"deletions":3},{"filePath":"/__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/make-bridge-ontologies-from-xrefs.pl","relativePath":"src/ontology/make-bridge-ontologies-from-xrefs.pl","type":"update","patch":"Index: /__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/make-bridge-ontologies-from-xrefs.pl\n===================================================================\n--- /__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/make-bridge-ontologies-from-xrefs.pl\n+++ /__w/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/make-bridge-ontologies-from-xrefs.pl\n@@ -83,9 +83,9 @@\n             }\n             elsif ($t eq 'gd') {\n                 print $fh \"intersection_of: $id ! $n\\n\";\n                 if (exists($lsxrefs{$x})) {\n-                    $rel = \"occurs_in\";\n+                    $rel = \"in_taxon\";\n              