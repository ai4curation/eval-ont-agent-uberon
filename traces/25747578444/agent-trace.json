f' some 'thoracic aorta'.\\n\\n\\n\",\n  \"comments\": [\n    {\n      \"id\": \"IC_kwDOAAidd86z7QJX\",\n      \"author\": {\n        \"login\": \"aleixpuigb\"\n      },\n      \"authorAssociation\": \"MEMBER\",\n      \"body\": \"@dragon-ai-agent please make these changes.\",\n      \"createdAt\": \"2025-06-30T10:38:34Z\",\n      \"includesCreatedEdit\": false,\n      \"isMinimized\": false,\n      \"minimizedReason\": \"\",\n      \"reactionGroups\": [],\n      \"url\": \"https://github.com/obophenotype/uberon/issues/3572#issuecomment-3018654295\",\n      \"viewerDidAuthor\": false\n    }\n  ],\n  \"title\": \"Revise esophagus and esophageal artery partonomy\",","truncated":false,"loaded":[]},"title":"__issue_context__.json","time":{"start":1778603613983,"end":1778603613995}},"id":"prt_e1d09489a001inbDl0D1M3dllb","sessionID":"ses_1e2f7312dffeF00Cnru3Ed01Z5","messageID":"msg_e1d08cfa3001X7l49D6h41Ht9b"}}
