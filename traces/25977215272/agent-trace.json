{"type":"text","timestamp":1778978934968,"sessionID":"ses_1cc988aceffekQn0T7aXIicDyg","part":{"id":"prt_e336837ec001h0sw5BnJvGCHIV","messageID":"msg_e33680f72001VADhA97o3QacKP","sessionID":"ses_1cc988aceffekQn0T7aXIicDyg","type":"text","text":"The local checkout doesn’t have a `terms/` directory yet, which is fine for this workflow. I’m moving to source selection and new-term metadata conventions so the eventual edit is minimal and check-in-ready.","time":{"start":1778978928620,"end":1778978934966}}}
