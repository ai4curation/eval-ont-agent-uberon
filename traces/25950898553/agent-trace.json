{"type":"tool_use","timestamp":1778903957600,"sessionID":"ses_1d1105b2dffeoypsZAOjVXoVJo","part":{"type":"tool","tool":"read","callID":"functions.read:30","state":{"status":"completed","input":{"filePath":"/home/runner/work/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/uberon.Makefile","offset":1315,"limit":120},"output":"<path>/home/runner/work/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/uberon.Makefile</path>\n<type>file</type>\n<content>\n1315: \n1316: \n1317: # ----------------------------------------\n1318: # BRIDGES\n1319: # ----------------------------------------\n1320: ifeq ($(BRI),true)\n1321: \n1322: # Those bridges are generated separately (see below).\n1323: EXTERN_BRIDGES = $(BRIDGEDIR)/uberon-bridge-to-mba.owl \\\n1324: \t\t $(BRIDGEDIR)/uberon-bridge-to-dmba.owl\n1325: \n1326: # 1. Prepare the ruleset file.\n1327: # The ruleset file is maintained with the help of the Python script\n1328: # to automatically insert the taxon-specific rules.\n1329: $(TMPDIR)/bridges.rules: $(SCRIPTSDIR)/taxa.py config/taxa.yaml $(BRIDGEDIR)/bridges.rules\n1330: \tpython3 $(SCRIPTSDIR)/taxa.py make-rules config/taxa.yaml $(BRIDGEDIR)/bridges.rules > $@\n1331: \n1332: # 2. Generate the bridges from the \"meta\" mapping set and the CL set.\n1333: # Note that merging CL here is not strictly necessary, but doing so\n1334: # allows sssom-inject to filter out any mapping with an inexistent or\n1335: # obsolete Uberon/CL class.\n1336: $(TMPDIR)/bridges: $(SRC) $(IMPORTDIR)/local-cl.owl \\\n1337: \t\t   $(MAPPINGDIR)/uberon.sssom.tsv $(MAPPINGDIR)/cl.sssom.tsv \\\n1338: \t\t   $(TMPDIR)/bridges.rules $(BRIDGEDIR)/bridges.dispatch \\\n1339: \t\t   $(EXTERN_BRIDGES) | all_robot_plugins\n1340: \t$(ROBOT) merge -i $(SRC) -i $(IMPORTDIR)/local-cl.owl \\\n1341: \t\t sssom:inject --sssom $(MAPPINGDIR)/uberon.sssom.tsv \\\n1342: \t\t              --sssom $(MAPPINGDIR)/cl.sssom.tsv \\\n1343: \t\t              --ruleset $(TMPDIR)/bridges.rules \\\n1344: \t\t              --exclude-rule xrefs \\\n1345: \t\t              --dispatch-table $(BRIDGEDIR)/bridges.dispatch && \\\n1346: \ttouch $@\n1347: \n1348: # The above step creates RDF/XML bridges, turn them to OBO.\n1349: # FIXME: Is this really necessary? Previously the OBO files were an\n1350: # intermediate towards the final bridge files in OWL, but now we can\n1351: # generate bridge files in OWL (or any format we want) directly, so\n1352: # I don't think we need to carry over OBO files.\n1353: $(BRIDGEDIR)/%.obo: $(BRIDGEDIR)/%.owl\n1354: \t$(ROBOT) convert -i $< --check false -f obo -o $@\n1355: \n1356: \n1357: # Custom bridges\n1358: # ----------------------------------------\n1359: # All bridges that are not generated from SSSOM sets.\n1360: \n1361: # Bridges to MBA and DMBA are now manually curated and generated in\n1362: # https://github.com/brain-bican/mouse_brain_atlas_ontology and\n1363: # https://github.com/brain-bican/developing_mouse_brain_atlas_ontology,\n1364: # respectively.\n1365: UBERON_BRIDGE_MBA = \"https://raw.githubusercontent.com/brain-bican/mouse_brain_atlas_ontology/main/src/ontology/new-bridges/new-uberon-bridge-to-mba.owl\"\n1366: UBERON_BRIDGE_DMBA = \"https://raw.githubusercontent.com/brain-bican/developing_mouse_brain_atlas_ontology/main/src/ontology/new-bridges/new-uberon-bridge-to-dmba.owl\"\n1367: \n1368: # Only refresh those bridges when we explicitly allow refreshing\n1369: # external resources (MIR=true).\n1370: ifeq ($(strip $(MIR)),true)\n1371: $(BRIDGEDIR)/uberon-bridge-to-mba.owl: $(SRC)\n1372: \t$(ROBOT) annotate -I $(UBERON_BRIDGE_MBA) --ontology-iri $(ONTBASE)/$@ -o $@\n1373: \n1374: $(BRIDGEDIR)/uberon-bridge-to-dmba.owl: $(SRC)\n1375: \t$(ROBOT) annotate -I $(UBERON_BRIDGE_DMBA) --ontology-iri $(ONTBASE)/$@ -o $@\n1376: endif\n1377: \n1378: else # BRI=false\n1379: # Skip the production of bridges entirely.\n1380: $(TMPDIR)/bridges:\n1381: \ttouch $@\n1382: endif\n1383: \n1384: \n1385: # ----------------------------------------\n1386: # COMPONENTS\n1387: # ----------------------------------------\n1388: \n1389: $(COMPONENTSDIR)/in-subset.owl: $(SRC) $(TEMPLATEDIR)/in-subset.template.tsv\n1390: \t$(ROBOT) template --template $(TEMPLATEDIR)/in-subset.template.tsv \\\n1391: \t\t annotate --ontology-iri $(ONTBASE)/$@ \\\n1392: \t\t          --output $(COMPONENTSDIR)/in-subset.owl\n1393: \n1394: $(COMPONENTSDIR)/vasculature_class.owl: $(TEMPLATEDIR)/vasculature_class.owl\n1395: \t$(ROBOT) merge -i $< annotate --ontology-iri $(ONTBASE)/$@ --output $@\n1396: \n1397: HRA_SUBSET_URL=\"https://raw.githubusercontent.com/hubmapconsortium/ccf-validation-tools/master/owl/UB_ASCTB_subset.owl\"\n1398: $(TMPDIR)/hra_subset.owl:\n1399: \twget $(HRA_SUBSET_URL) -O $@\n1400: \n1401: ifeq ($(strip $(MIR)),true)\n1402: $(COMPONENTSDIR)/hra_subset.owl: $(TMPDIR)/hra_subset.owl\n1403: \t$(ROBOT) merge -i $< annotate --ontology-iri $(ONTBASE)/$@ --output $@\n1404: endif\n1405: \n1406: 3D_IMAGES_COMP_URL=\"https://raw.githubusercontent.com/hubmapconsortium/ccf-validation-tools/master/owl/hra_uberon_3d_images.owl\"\n1407: $(TMPDIR)/hra_depiction_3d_images.owl:\n1408: \twget $(3D_IMAGES_COMP_URL) -O $@\n1409: \n1410: $(COMPONENTSDIR)/hra_depiction_3d_images.owl: $(TMPDIR)/hra_depiction_3d_images.owl\n1411: \t$(ROBOT) merge -i $< annotate --ontology-iri $(ONTBASE)/$@ --output $@\n1412: \n1413: \n1414: # The mappings.owl component contains cross-references to foreign\n1415: # ontologies that provide their own mappings as a SSSOM set. This\n1416: # component ensures those mappings are visible to Uberon editors and\n1417: # users.\n1418: $(COMPONENTSDIR)/mappings.owl: $(SRC) $(EXTERNAL_SSSOM_SETS) | all_robot_plugins\n1419: \t$(ROBOT) sssom:inject -i $< \\\n1420: \t\t              $(foreach set, $(EXTERNAL_SSSOM_SETS), --sssom $(set)) \\\n1421: \t\t              --ruleset $(SCRIPTSDIR)/mappings-to-xrefs.rules \\\n1422: \t\t              --error-on-unshortenable-iris \\\n1423: \t\t              --no-merge --bridge-file $@ \\\