{"type":"tool_use","timestamp":1778903946880,"sessionID":"ses_1d1105b2dffeoypsZAOjVXoVJo","part":{"type":"tool","tool":"read","callID":"functions.read:20","state":{"status":"completed","input":{"filePath":"/home/runner/work/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/make-bridge-ontologies-from-xrefs.pl"},"output":"<path>/home/runner/work/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/make-bridge-ontologies-from-xrefs.pl</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/perl -w\n2: use strict;\n3: use FileHandle;\n4: \n5: my %fhmap = ();\n6: my %tmap = ();\n7: my $id;\n8: my $n;\n9: my $n_xrefs = 0;\n10: my $stype;\n11: my %nh = ();\n12: my %lsxrefs = ();\n13: \n14: my @fns = ();\n15: my $base = 'uberon';\n16: \n17: while ($ARGV[0] =~ /^\\-/) {\n18:     my $opt = shift @ARGV;\n19:     if ($opt eq '-b' || $opt eq '--base') {\n20:         $base = shift @ARGV;\n21:     }\n22:     elsif ($opt eq '-l' || $opt eq '--life-cycle-xrefs') {\n23:         open(F, shift @ARGV);\n24:         while (<F>) {\n25:             chomp;\n26:             $lsxrefs{$_} = 1;\n27:         }\n28:         close(F);\n29:     }\n30: }\n31: \n32: while (<>) {\n33:     chomp;\n34:     if (/^treat-xrefs-as-equivalent:\\s*(\\S+)/) {\n35:         mk_bridge('equivalent',$1);\n36:     }\n37:     elsif (/^treat-xrefs-as-has-subclass:\\s*(\\S+)/) {\n38:         mk_bridge('has-subclass',$1);\n39:     }\n40:     #elsif (/^treat-xrefs-as-is_a:\\s*(\\S+)/) {\n41:     #    mk_bridge('is_a',$1);\n42:     #}\n43:     elsif (/^treat-xrefs-as-reverse-genus-differentia:\\s*(\\S+)\\s+(\\S+)\\s+(\\S+)/) {\n44:         mk_bridge('gd',$1,$2,$3);\n45:     }\n46:     elsif (/^\\[(\\S+)\\]/) {\n47:         $stype = $1;\n48:     }\n49:     elsif (/^id:\\s*(\\S+)/) {\n50:         $id = $1;\n51:         $n = '';\n52:         if (/^id:\\s*\\S+\\s+\\!\\s+(.*)/) {\n53:             $n = $1;\n54:         }\n55:     }\n56:     elsif (/^name:\\s*(.*)/) {\n57:         $n = $1;\n58:         $nh{$id} = $n;\n59:     }\n60:     elsif (/^xref:\\s*(\\S+)(.*)/) {\n61:         next unless $stype eq 'Term';\n62:         my $x = $1;\n63:         my $cmt = $2;\n64:         $cmt =~ s/.*\\!\\s*//;\n65:         if ($x =~ /^(\\S+)[:\\/]([\\w\\-]+)$/) {\n66:             my $s = $1;\n67:             my $fh = $fhmap{$s};\n68:             if ($fh) {\n69:                 $n_xrefs++;\n70:                 my ($t,$rel,$filler) = @{$tmap{$s}};\n71:                 $n = $nh{$id};\n72:                 print $fh \"[Term]\\n\";\n73:                 print $fh \"id: $x ! $cmt\\n\";\n74:                 my $unique_label = mk_unique_label($s,$n);\n75:                 if ($n) {\n76:                     print $fh \"property_value: IAO:0000589 \\\"$unique_label\\\" xsd:string\\n\";\n77:                 }\n78:                 if ($t eq 'equivalent') {\n79:                     print $fh \"equivalent_to: $id ! $n\\n\";\n80:                 }\n81:                 elsif ($t eq 'has-subclass') {\n82:                     print $fh \"is_a: $id ! $n\\n\";\n83:                 }\n84:                 elsif ($t eq 'gd') {\n85:                     print $fh \"intersection_of: $id ! $n\\n\";\n86:                     if (exists($lsxrefs{$x})) {\n87:                         $rel = \"occurs_in\";\n88:                     }\n89:                     print $fh \"intersection_of: $rel $filler\\n\";\n90:                 }\n91:                 else {\n92:                     die $t;\n93:                 }\n94:                 print $fh \"\\n\";\n95:             }\n96:         }\n97:     }\n98: }\n99: print STDERR \"n_xrefs: $n_xrefs\\n\";\n100: \n101: \n102: foreach my $s (keys %fhmap) {\n103:     my $fh = $fhmap{$s};\n104:     #if ($tmap{$s}->[0] eq 'gd' && $base eq 'uberon') {\n105:     if ($tmap{$s}->[0] eq 'gd') {\n106:         my ($t,$rel,$filler) = @{$tmap{$s}};\n107:         # hidden GCI\n108:         print $fh \"[Term]\\n\";\n109:         print $fh \"id: $s:ENTITY\\n\";\n110:         print $fh \"name: $s entity\\n\";\n111:         print $fh \"intersection_of: UBERON:0001062 ! anatomical entity\\n\";\n112:         print $fh \"intersection_of: $rel $filler\\n\";\n113:         print $fh \"relationship: only_in_taxon $filler\\n\\n\";\n114:         print $fh \"[Typedef]\\n\";\n115:         print $fh \"id: part_of\\n\";\n116:         print $fh \"xref: BFO:0000050\\n\";\n117:         print $fh \"is_transitive: true\\n\\n\";\n118:         print $fh \"[Typedef]\\n\";\n119:         print $fh \"id: only_in_taxon\\n\";\n120:         print $fh \"xref: RO:0002160\\n\\n\";\n121:     }\n122: \n123:     my $prefix = \"http://purl.obolibrary.org/obo/\".lc($s);\n124:     print $fh \"[Typedef]\\n\";\n125:     print $fh \"id: part_of\\n\";\n126:     print $fh \"xref: BFO:0000050\\n\\n\";\n127:     print $fh \"[Typedef]\\n\";\n128:     print $fh \"id: develops_from\\n\";\n129:     print $fh \"xref: RO:0002225\\n\\n\";\n130:     print $fh \"[Typedef]\\n\";\n131:     print $fh \"id: occurs_in\\n\";\n132:     print $fh \"xref: BFO:0000066\\n\\n\";\n133: \n134:     open(F,\"ftr.obo\");\n135:     while(<F>) {\n136:         print $fh $_;\n137:     }\n138:     close(F);\n139: \n140: \n141:     $fh->close;\n142: }\n143: foreach my $ont (@fns) {\n144:     #my $cmd = \"obolib-obo2owl --allow-dangling $ont.obo -o $ont.owl\";\n145:     my $cmd = \"owltools $ont.obo -o $ont.owl\";\n146:     if ($ont eq '') {\n147:         # TODO - fix obo2owl\n148:         $cmd .= ' && perl -pi -ne \"s@http://purl.obolibrary.org/obo/NIF_GrossAnatomy#_@http://ontology.neuinfo.org/NIF/BiomaterialEntities/NIF-GrossAnatomy.owl#@\" '.\"$ont.owl\";\n149:     }\n150:     if (system($cmd)) {\n151:         print STDERR \"REMOVING: $ont.obo\\n\";\n152:         system(\"rm $ont.obo\");\n153:     }\n154:     \n155: }\n156: \n157: print STDERR \"n_xrefs: $n_xrefs\\n\";\n158: \n159: exit 0;\n160: \n161: sub mk_unique_label {\n162:     my ($s,$n) = @_;\n163:     $s =~ s/^AAO$/amphibian/;\n164:     $s =~ s/^FBbt$/drosophila/;\n165:     $s =~ s/^FMA$/post-embryonic human/; \n166:     $s =~ s/^HAO$/hymenoptera/; \n167:     $s =~ s/^MA$/post-embryonic mouse/; \n168:     $s =~ s/^SPD$/spider/; \n169:     $s =~ s/^TAO$/teleost/; \n170:     $s =~ s/^WBbt$/worm/;\n171:     $s =~ s/^WBls$/worm/;\n172:     $s =~ s/^XAO$/xenopus/; \n173:     $s =~ s/^ZFA$/zebrafish/; \n174:     $s =~ s/^EHDAA2$/embryonic human/; \n175:     $s =~ s/^EMAPA$/embryonic mouse/; \n176:     return \"$n ($s)\";\n177: }\n178: \n179: sub mk_bridge {\n180:     my ($t,$s,@args) = @_;\n181:     my $ont = lc(\"$base-bridge-to-$s\");\n182:     my $fn = \"$ont.obo\";\n183:     push(@fns,$ont);\n184:     print STDERR \"Writing to: $fn\\n\";\n185: \n186:     my $date = `date \"+%Y-%m-%d\"`;\n187:     chomp $date;\n188: \n189:     my $fh = FileHandle->new(\">$fn\") || die $fn;\n190:     print $fh \"ontology: uberon/bridge/$ont\\n\";\n191:     print $fh \"data-version: $date\\n\";\n192:     print $fh \"property_value: seeAlso \\\"http://purl.obolibrary.org/obo/uberon/references/reference_0000026\\\" xsd:anyURI\\n\";\n193:     if (-f \"hdr-$fn\") {\n194:         open(F,\"hdr-$fn\");\n195:         while(<F>) {\n196:             print $fh $_;\n197:         }\n198:         close(F);\n199:     }\n200:     #print $fh ann_str('dc-description' =>\"bridging axioms between uberon and $ont\");\n201:     #print $fh ann_uri('foaf-homepage' => \"bridging axioms between uberon and $ont\");\n202:     print $fh \"\\n\";\n203:     $fhmap{$s} = $fh;\n204:     $tmap{$s} = [$t,@args];\n205: }\n\n(End of file - total 205 lines)\n</content>","metadata":{"preview":"#!/usr/bin/perl -w\nuse strict;\nuse FileHandle;\n\nmy %fhmap = ();\nmy %tmap = ();\nmy $id;\nmy $n;\nmy $n_xrefs = 0;\nmy $stype;\nmy %nh = ();\nmy %lsxrefs = ();\n\nmy @fns = ();\nmy $base = 'uberon';\n\nwhile ($ARGV[0] =~ /^\\-/) {\n    my $opt = shift @ARGV;\n    if ($opt eq '-b' || $opt eq '--base') {\n        $base = shift @ARGV;","truncated":false,"loaded":[]},"title":"src/ontology/make-bridge-ontologies-fro