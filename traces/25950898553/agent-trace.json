:     }\n60:     elsif (/^xref:\\s*(\\S+)(.*)/) {\n61:         next unless $stype eq 'Term';\n62:         my $x = $1;\n63:         my $cmt = $2;\n64:         $cmt =~ s/.*\\!\\s*//;\n65:         if ($x =~ /^(\\S+)[:\\/]([\\w\\-]+)$/) {\n66:             my $s = $1;\n67:             my $fh = $fhmap{$s};\n68:             if ($fh) {\n69:                 $n_xrefs++;\n70:                 my ($t,$rel,$filler) = @{$tmap{$s}};\n71:                 $n = $nh{$id};\n72:                 print $fh \"[Term]\\n\";\n73:                 print $fh \"id: $x ! $cmt\\n\";\n74:                 my $unique_label = mk_unique_label($s,$n);\n75:                 if ($n) {\n76:                     print $fh \"property_value: IAO:0000589 \\\"$unique_label\\\" xsd:string\\n\";\n77:                 }\n78:                 if ($t eq 'equivalent') {\n79:                     print $fh \"equivalent_to: $id ! $n\\n\";\n80:                 }\n81:                 elsif ($t eq 'has-subclass') {\n82:                     print $fh \"is_a: $id ! $n\\n\";\n83:                 }\n84:                 elsif ($t eq 'gd') {\n85:                     print $fh \"intersection_of: $id ! $n\\n\";\n86:                     if (exists($lsxrefs{$x})) {\n87:                         $rel = \"in_taxon\";\n88:                     }\n89:                     print $fh \"intersection_of: $rel $filler\\n\";\n90:                 }\n91:                 else {\n92:                     die $t;\n93:                 }\n94:                 print $fh \"\\n\";\n95:             }\n96:         }\n97:     }\n98: }\n99: print STDERR \"n_xrefs: $n_xrefs\\n\";\n100: \n101: \n102: foreach my $s (keys %fhmap) {\n103:     my $fh = $fhmap{$s};\n104:     #if ($tmap{$s}->[0] eq 'gd' && $base eq 'uberon') {\n105:     if ($tmap{$s}->[0] eq 'gd') {\n106:         my ($t,$rel,$filler) = @{$tmap{$s}};\n107:         # hidden GCI\n108:         print $fh \"[Term]\\n\";\n109:         print $fh \"id: $s:ENTITY\\n\";\n110:         print $fh \"name: $s entity\\n\";\n