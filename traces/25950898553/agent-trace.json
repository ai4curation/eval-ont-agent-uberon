{"type":"tool_use","timestamp":1778903954223,"sessionID":"ses_1d1105b2dffeoypsZAOjVXoVJo","part":{"type":"tool","tool":"read","callID":"functions.read:28","state":{"status":"completed","input":{"filePath":"/home/runner/work/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/Makefile"},"output":"<path>/home/runner/work/eval-ont-agent-uberon/eval-ont-agent-uberon/src/ontology/Makefile</path>\n<type>file</type>\n<content>\n1: # ----------------------------------------\n2: # Makefile for uberon\n3: # Generated using ontology-development-kit\n4: # ODK Version: v1.5.4\n5: # ----------------------------------------\n6: # IMPORTANT: DO NOT EDIT THIS FILE. To override default make goals, use uberon.Makefile instead\n7: \n8: \n9: # ----------------------------------------\n10: # More information: https://github.com/INCATools/ontology-development-kit/\n11: \n12: # Fingerprint of the configuration file when this Makefile was last generated\n13: CONFIG_HASH=                2280340b1810b2a972296e0c511d5e87711793855300136263ac0b8801de9cf3\n14: \n15: \n16: # ----------------------------------------\n17: # Standard Constants\n18: # ----------------------------------------\n19: # these can be overwritten on the command line\n20: \n21: OBOBASE=                    http://purl.obolibrary.org/obo\n22: URIBASE=                    http://purl.obolibrary.org/obo\n23: ONT=                        uberon\n24: ONTBASE=                    http://purl.obolibrary.org/obo/uberon\n25: EDIT_FORMAT=                obo\n26: SRC =                       $(ONT)-edit.$(EDIT_FORMAT)\n27: MAKE_FAST=                  $(MAKE) IMP=false PAT=false COMP=false MIR=false\n28: CATALOG=                    catalog-v001.xml\n29: ROBOT=                      robot --catalog $(CATALOG)\n30: OWLTOOLS_MEMORY=            20G\n31: OWLTOOLS=                   OWLTOOLS_MEMORY=$(OWLTOOLS_MEMORY) owltools --use-catalog\n32: RELEASEDIR=                 ../..\n33: REPORTDIR=                  reports\n34: TEMPLATEDIR=                ../templates\n35: TMPDIR=                     tmp\n36: MIRRORDIR=                  mirror\n37: IMPORTDIR=                  imports\n38: SUBSETDIR=                  subsets\n39: SCRIPTSDIR=                 ../scripts\n40: UPDATEREPODIR=              target\n41: SPARQLDIR =                 ../sparql\n42: COMPONENTSDIR =             components\n43: ROBOT_PROFILE =             profile.txt\n44: REPORT_FAIL_ON =            ERROR\n45: REPORT_LABEL =              \n46: REPORT_PROFILE_OPTS =       --profile $(ROBOT_PROFILE)\n47: OBO_FORMAT_OPTIONS =        \n48: SPARQL_VALIDATION_CHECKS =  equivalent-classes owldef-self-reference illegal-annotation-property taxon-range orcid-contributor obsolete-replaced_by xrefs-mesh-pattern label-synonym-polysemy id-format \n49: SPARQL_EXPORTS =            basic-report \n50: ODK_VERSION_MAKEFILE =      v1.5.4\n51: \n52: TODAY ?=                    $(shell date +%Y-%m-%d)\n53: OBODATE ?=                  $(shell date +'%d:%m:%Y %H:%M')\n54: VERSION=                    $(TODAY)\n55: ANNOTATE_ONTOLOGY_VERSION = annotate -V $(ONTBASE)/releases/$(VERSION)/$@ --annotation owl:versionInfo $(VERSION)\n56: ANNOTATE_CONVERT_FILE =     annotate --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) convert -f ofn --output $@.tmp.owl && mv $@.tmp.owl $@\n57: OTHER_SRC =                 $(PATTERNDIR)/definitions.owl $(COMPONENTSDIR)/disjoint_union_over.owl $(COMPONENTSDIR)/mappings.owl $(COMPONENTSDIR)/in-subset.owl $(COMPONENTSDIR)/hra_subset.owl $(COMPONENTSDIR)/vasculature_class.owl $(COMPONENTSDIR)/hra_depiction_3d_images.owl \n58: ONTOLOGYTERMS =             $(TMPDIR)/ontologyterms.txt\n59: EDIT_PREPROCESSED =         $(TMPDIR)/$(ONT)-preprocess.owl\n60: PATTERNDIR=                 ../patterns\n61: PATTERN_TESTER=             dosdp validate -i\n62: DOSDPT=                     dosdp-tools\n63: PATTERN_RELEASE_FILES=      $(PATTERNDIR)/definitions.owl $(PATTERNDIR)/pattern.owl\n64: \n65: MAPPINGDIR=                 ../mappings\n66: MAPPING_TESTER=             sssom validate\n67: SSSOMPY=                    sssom\n68: MAPPINGS=                   fbbt cl sslso biomappings uberon-local uberon import-corrections \n69: MAPPING_RELEASE_FILES=      $(foreach n,$(MAPPINGS), $(MAPPINGDIR)/$(n).sssom.tsv)\n70: \n71: \n72: FORMATS = $(sort  owl obo json owl)\n73: FORMATS_INCL_TSV = $(sort $(FORMATS) tsv)\n74: RELEASE_ARTEFACTS = $(sort $(ONT)-base $(ONT)-full $(ONT)-simple $(ONT)-basic collected-metazoan composite-metazoan composite-metazoan-basic composite-vertebrate composite-vertebrate-basic collected-lifestages composite-lifestages common-anatomy )\n75: \n76: ifeq ($(ODK_DEBUG),yes)\n77: ODK_DEBUG_FILE = debug.log\n78: SHELL = $(SCRIPTSDIR)/run-command.sh\n79: endif\n80: \n81: # ----------------------------------------\n82: # Top-level targets\n83: # ----------------------------------------\n84: \n85: .PHONY: .FORCE\n86: \n87: .PHONY: all\n88: all: all_odk\n89: \n90: .PHONY: all_odk\n91: all_odk: odkversion config_check test custom_reports all_assets\n92: \n93: .PHONY: test\n94: test: odkversion dosdp_validation reason_test sparql_test robot_reports $(REPORTDIR)/validate_profile_owl2dl_$(ONT).owl.txt\n95: \techo \"Finished running all tests successfully.\"\n96: \n97: .PHONY: test\n98: test_fast:\n99: \t$(MAKE_FAST) test\n100: \n101: .PHONY: release_diff\n102: release_diff: $(REPORTDIR)/release-diff.md\n103: \n104: .PHONY: reason_test\n105: reason_test: $(EDIT_PREPROCESSED)\n106: \t$(ROBOT) reason --input $< --reasoner ELK --equivalent-classes-allowed asserted-only \\\n107: \t\t--exclude-tautologies structural --output test.owl && rm test.owl\n108: \n109: .PHONY: odkversion\n110: odkversion:\n111: \t@echo \"ODK Makefile $(ODK_VERSION_MAKEFILE)\"\n112: \t@odk-info --tools\n113: .PHONY: config_check\n114: config_check:\n115: \t@if [ \"$$(sha256sum $(ONT)-odk.yaml | cut -c1-64)\" = \"$(CONFIG_HASH)\" ]; then \\\n116: \t\techo \"Repository is up-to-date.\" ; else \\\n117: \t\techo \"Your ODK configuration has changed since this Makefile was generated. You may need to run 'make update_repo'.\" ; fi\n118: \n119: \n120: $(TMPDIR) $(REPORTDIR) $(MIRRORDIR) $(IMPORTDIR) $(COMPONENTSDIR) $(SUBSETDIR):\n121: \tmkdir -p $@\n122: \n123: # ----------------------------------------\n124: # ODK-managed ROBOT plugins\n125: # ----------------------------------------\n126: \n127: # Make sure ROBOT knows where to find plugins\n128: export ROBOT_PLUGINS_DIRECTORY=$(TMPDIR)/plugins\n129: \n130: # Override this rule in uberon.Makefile to install custom plugins\n131: .PHONY: custom_robot_plugins\n132: custom_robot_plugins:\n133: \n134: \n135: .PHONY: extra_robot_plugins\n136: extra_robot_plugins:  $(ROBOT_PLUGINS_DIRECTORY)/uberon.jar \n137: \n138: \n139: # Install all ROBOT plugins to the runtime plugins directory\n140: .PHONY: all_robot_plugins\n141: all_robot_plugins: $(foreach plugin,$(notdir $(wildcard /tools/robot-plugins/*.jar)),$(ROBOT_PLUGINS_DIRECTORY)/$(plugin)) \\\n142: \t\t   $(foreach plugin,$(notdir $(wildcard ../../plugins/*.jar)),$(ROBOT_PLUGINS_DIRECTORY)/$(plugin)) \\\n143: \t\t   custom_robot_plugins extra_robot_plugins  \\\n144: \n145: # Default rule to install plugins\n146: $(ROBOT_PLUGINS_DIRECTORY)/%.jar:\n147: \t@mkdir -p $(ROBOT_PLUGINS_DIRECTORY)\n148: \t@if [ -f ../../plugins/$*.jar ]; then        \\\n149: \t\tln ../../plugins/$*.jar $@ ;         \\\n150: \telif [ -f /tools/robot-plugins/$*.jar ]; then \\\n151: \t\tcp /tools/robot-plugins/$*.jar $@ ;  \\\n152: \tfi\n153: \n154: # Specific rules for supplementary plugins defined in configuration\n155: \n156: $(ROBOT_PLUGINS_DIRECTORY)/uberon.jar:\n157: \tcurl -L -o $@ https://github.com/gouttegd/uberon-robot-plugin/releases/download/uberon-robot-plugin-0.3.2/uberon.jar\n158: \n159: \n160: # ----------------------------------------\n161: # Release assets\n162: # ----------------------------------------\n163: \n164: MAIN_PRODUCTS = $(sort $(foreach r,$(RELEASE_ARTEFACTS), $(r)) $(ONT))\n165: MAIN_GZIPPED  = \n166: MAIN_FILES    = $(foreach n,$(MAIN_PRODUCTS), $(foreach f,$(FORMATS), $(n).$(f))) $(MAIN_GZIPPED)\n167: SRCMERGED     = $(TMPDIR)/merged-$(SRC)\n168: \n169: .PHONY: all_main\n170: all_main: $(MAIN_FILES)\n171: \n172: # ----------------------------------------\n173: # Import assets\n174: # ----------------------------------------\n175: \n176: \n177: IMPORTS =  pr cl go envo ro bspo chebi pato bfo ncbitaxon ncbitaxondisjoints nbo orcidio omo\n178: \n179: IMPORT_ROOTS =  $(IMPORTDIR)/merged_import\n180: IMPORT_OWL_FILES = $(foreach n,$(IMPORT_ROOTS), $(n).owl)\n181: IMPORT_FILES = $(IMPORT_OWL_FILES)\n182: \n183: \n184: .PHONY: all_imports\n185: all_imports: $(IMPORT_FILES)\n186: \n187: # ----------------------------------------\n188: # Subset assets\n189: # ----------------------------------------\n190: \n191: \n192: SUBSETS =  appendicular-minimal circulatory-minimal cranial-minimal cumbo digestive-minimal excretory-minimal human-view immune-minimal life-stages-composite life-stages-core life-stages-minimal merged-partonomy mouse-view musculoskeletal-minimal nephron-minimal nervous-minimal pulmonary-minimal renal-minimal reproductive-minimal sensory-minimal xenopus-view amniote-view euarchontoglires-view\n193: \n194: SUBSET_ROOTS = $(patsubst %, $(SUBSETDIR)/%, $(SUBSETS))\n195: SUBSET_FILES = $(foreach n,$(SUBSET_ROOTS), $(foreach f,$(FORMATS_INCL_TSV), $(n).$(f)))\n196: \n197: .PHONY: all_subsets\n198: all_subsets: $(SUBSET_FILES)\n199: \n200: # ----------------------------------------\n201: # Mapping assets\n202: # ----------------------------------------\n203: \n204: \n205: MAPPINGS =  fbbt cl sslso biomappings uberon-local uberon import-corrections\n206: \n207: MAPPING_FILES = $(patsubst %, $(MAPPINGDIR)/%.sssom.tsv, $(MAPPINGS))\n208: \n209: .PHONY: all_mappings\n210: all_mappings: $(MAPPING_FILES)\n211: \n212: \n213: # ----------------------------------------\n214: # QC Reports & Utilities\n215: # ----------------------------------------\n216: \n217: OBO_REPORT =  $(SRC)-obo-report\n218: REPORTS = $(OBO_REPORT)\n219: REPORT_FILES = $(patsubst %, $(REPORTDIR)/%.tsv, $(REPORTS))\n220: \n221: .PHONY: robot_reports\n222: robot_reports: $(REPORT_FILES)\n223: \n224: .PHONY: all_reports\n225: all_reports: custom_reports robot_reports\n226: \n227: # ----------------------------------------\n228: # ROBOT OWL Profile checking\n229: # ----------------------------------------\n230: \n231: # The merge step is necessary to avoid undeclared entity violations.\n232: $(REPORTDIR)/validate_profile_owl2dl_%.txt: % | $(REPORTDIR) $(TMPDIR)\n233: \t$(ROBOT) merge -i $< convert -f ofn -o $(TMPDIR)/validate.ofn\n234: \t$(ROBOT) validate-profile --profile DL -i $(TMPDIR)/validate.ofn -o $@ || { cat $@ && exit 1; }\n235: .PRECIOUS: $(REPORTDIR)/validate_profile_owl2dl_%.txt\n236: \n237: validate_profile_%: $(REPORTDIR)/validate_profile_owl2dl_%.txt\n238: \techo \"$* profile validation completed.\"\n239: \n240: # ----------------------------------------\n241: # Sparql queries: Q/C\n242: # ----------------------------------------\n243: \n244: # these live in the ../sparql directory, and have suffix -violation.sparql\n245: # adding the name here will make the violation check live.\n246: \n247: SPARQL_VALIDATION_QUERIES = $(foreach V,$(SPARQL_VALIDATION_CHECKS),$(SPARQLDIR)/$(V)-violation.sparql)\n248: \n249: sparql_test:  $(EDIT_PREPROCESSED) | $(REPORTDIR)\n250: ifneq ($(SPARQL_VALIDATION_QUERIES),)\n251:   \n252: \t$(ROBOT) verify -i $(EDIT_PREPROCESSED) --queries $(SPARQL_VALIDATION_QUERIES) -O $(REPORTDIR)\n253: endif\n254: \n255: # ----------------------------------------\n256: # ROBOT report\n257: # ----------------------------------------\n258: \n259: $(REPORTDIR)/$(SRC)-obo-report.tsv: $(SRCMERGED) | $(REPORTDIR)\n260: \t$(ROBOT) report -i $< $(REPORT_LABEL) $(REPORT_PROFILE_OPTS) --fail-on $(REPORT_FAIL_ON) --print 5 -o $@\n261: \n262: $(REPORTDIR)/%-obo-report.tsv: % | $(REPORTDIR)\n263: \t$(ROBOT) report -i $< $(REPORT_LABEL) $(REPORT_PROFILE_OPTS) --fail-on $(REPORT_FAIL_ON) --print 5 -o $@\n264: \n265: check_for_robot_updates:\t\n266: \t@cut -f2 \"/tools/robot_report_profile.txt\" | sort > $(TMPDIR)/sorted_tsv2.txt\n267: \t@cut -f2 \"$(ROBOT_PROFILE)\" | sort > $(TMPDIR)/sorted_tsv1.txt\n268: \t@comm -23 $(TMPDIR)/sorted_tsv2.txt $(TMPDIR)/sorted_tsv1.txt > $(TMPDIR)/missing.txt\n269: \t@echo \"Missing tests:\"\n270: \t@cat $(TMPDIR)/missing.txt\n271: \t@rm $(TMPDIR)/sorted_tsv1.txt $(TMPDIR)/sorted_tsv2.txt $(TMPDIR)/missing.txt $(TMPDIR)/report_profile_robot.txt\n272: \n273: # ----------------------------------------\n274: # Release assets\n275: # ----------------------------------------\n276: \n277: ASSETS = \\\n278:   $(IMPORT_FILES) \\\n279:   $(MAIN_FILES) \\\n280:   $(PATTERN_RELEASE_FILES) \\\n281:   $(REPORT_FILES) \\\n282:   $(SUBSET_FILES) \\\n283:   $(MAPPING_FILES)\n284: \n285: RELEASE_ASSETS = \\\n286:   $(MAIN_FILES) \\\n287:   $(SUBSET_FILES)\n288: \n289: .PHONY: all_assets\n290: all_assets: $(ASSETS) check_rdfxml_assets\n291: \n292: .PHONY: show_assets\n293: show_assets:\n294: \techo $(ASSETS)\n295: \tdu -sh $(ASSETS)\n296: \n297: check_rdfxml_%: %\n298: \t@check-rdfxml  $<\n299: \n300: .PHONY: check_rdfxml_assets\n301: check_rdfxml_assets: $(foreach product,$(MAIN_PRODUCTS),check_rdfxml_$(product).owl)\n302: \n303: # ----------------------------------------\n304: # Release Management\n305: # ----------------------------------------\n306: \n307: KEEPRELATIONS=keeprelations.txt\n308: CLEANFILES=$(MAIN_FILES) $(SRCMERGED) $(EDIT_PREPROCESSED)\n309: # This should be executed by the release manager whenever time comes to make a release.\n310: # It will ensure that all assets/files are fresh, and will copy to release folder\n311: \n312: .PHONY: prepare_release\n313: prepare_release: all_odk\n314: \trsync -R $(RELEASE_ASSETS) $(RELEASEDIR) &&\\\n315: \tmkdir -p $(RELEASEDIR)/patterns && cp -rf $(PATTERN_RELEASE_FILES) $(RELEASEDIR)/patterns &&\\\n316: \trm -f $(CLEANFILES) &&\\\n317: \techo \"Release files are now in $(RELEASEDIR) - now you should commit, push and make a release \\\n318:         on your git hosting site such as GitHub or GitLab\"\n319: \n320: .PHONY: prepare_initial_release\n321: prepare_initial_release: all_assets\n322: \trsync -R $(RELEASE_ASSETS) $(RELEASEDIR) &&\\\n323: \tmkdir -p $(RELEASEDIR)/patterns && cp -rf $(PATTERN_RELEASE_FILES) $(RELEASEDIR)/patterns &&\\\n324: \trm -f $(patsubst %, ./%, $(CLEANFILES)) &&\\\n325: \tcd $(RELEASEDIR) && git add $(RELEASE_ASSETS)\n326: \n327: .PHONY: prepare_release_fast\n328: prepare_release_fast:\n329: \t$(MAKE) prepare_release IMP=false PAT=false MIR=false COMP=false\n330: \n331: CURRENT_RELEASE=$(ONTBASE).owl\n332: \n333: $(TMPDIR)/current-release.owl:\n334: \twget $(CURRENT_RELEASE) -O $@\n335: \n336: $(REPORTDIR)/release-diff.md: $(ONT).owl $(TMPDIR)/current-release.owl\n337: \t$(ROBOT) diff --labels true --left $(TMPDIR)/current-release.owl --right $(ONT).owl -f markdown -o $@\n338: \n339: # ------------------------\n340: # Imports: Seeding system \n341: # ------------------------\n342: \n343: # seed.txt contains all referenced entities\n344: IMPORTSEED=$(TMPDIR)/seed.txt\n345: PRESEED=$(TMPDIR)/pre_seed.txt\n346: \n347: $(SRCMERGED): $(EDIT_PREPROCESSED) $(OTHER_SRC)\n348: \t$(ROBOT) remove --input $< --select imports --trim false \\\n349: \t\tmerge  $(patsubst %, -i %, $(OTHER_SRC)) -o $@\n350: \n351: $(EDIT_PREPROCESSED): $(SRC)\n352: \t$(ROBOT) convert --input $< --format ofn --output $@\n353: \n354: $(PRESEED): $(SRCMERGED)\n355: \t$(ROBOT) query -f csv -i $< --query ../sparql/terms.sparql $@.tmp &&\\\n356: \tcat $@.tmp | sort | uniq >  $@\n357: \n358: SIMPLESEED=$(TMPDIR)/simple_seed.txt\n359: \n360: $(SIMPLESEED): $(SRCMERGED) $(ONTOLOGYTERMS)\n361: \t$(ROBOT) query -f csv -i $< --query ../sparql/simple-seed.sparql $@.tmp &&\\\n362: \tcat $@.tmp $(ONTOLOGYTERMS) | sort | uniq >  $@ &&\\\n363: \techo \"http://www.geneontology.org/formats/oboInOwl#SubsetProperty\" >> $@ &&\\\n364: \techo \"http://www.geneontology.org/formats/oboInOwl#SynonymTypeProperty\" >> $@\n365: \n366: \n367: ALLSEED = $(PRESEED)  $(TMPDIR)/all_pattern_terms.txt \\\n368: \n369: \n370: $(IMPORTSEED): $(ALLSEED) | $(TMPDIR)\n371: \tif [ $(IMP) = true ]; then cat $(ALLSEED) | sort | uniq > $@; fi\n372: \n373: ANNOTATION_PROPERTIES=rdfs:label IAO:0000115 OMO:0002000 \n374: \n375: # ----------------------------------------\n376: # Import modules\n377: # ----------------------------------------\n378: # Most ontologies are modularly constructed using portions of other ontologies\n379: # These live in the imports/ folder\n380: # This pattern uses ROBOT to generate an import module\n381: \n382: # Should be able to drop this if robot can just take a big messy list of terms as input.\n383: $(IMPORTDIR)/%_terms_combined.txt: $(IMPORTSEED) $(IMPORTDIR)/%_terms.txt\n384: \tif [ $(IMP) = true ]; then cat $^ | grep -v ^# | sort | uniq >  $@; fi\n385: \n386: \n387: ALL_TERMS_COMBINED = $(patsubst %, $(IMPORTDIR)/%_terms_combined.txt, $(IMPORTS))\n388: $(IMPORTDIR)/merged_terms_combined.txt: $(ALL_TERMS_COMBINED)\n389: \tif [ $(IMP) = true ]; then cat $^ | grep -v ^# | sort | uniq >  $@; fi\n390: \n391: \n392: $(IMPORTDIR)/merged_import.owl: $(MIRRORDIR)/merged.owl $(IMPORTDIR)/merged_terms_combined.txt\n393: \tif [ $(IMP) = true ]; then $(ROBOT) merge -i $< \\\n394: \t\tremove  --select \"<http://www.informatics.jax.org/marker/MGI:*>\" remove  --select \"<http://purl.obolibrary.org/obo/OBA_*>\" remove  --select \"<http://purl.obolibrary.org/obo/ENVO_*>\" remove  --select \"<http://purl.obolibrary.org/obo/OBI_*>\" remove  --select \"<http://purl.obolibrary.org/obo/GOCHE_*>\" remove  --select \"<http://www.genenames.org/cgi-bin/gene_symbol_report*>\" remove  --select \"<http://www.ncbi.nlm.nih.gov/gene/*>\" remove  --select \"<http://birdgenenames.org/cgnc/GeneReport*>\"  \\\n395: \t\textract -T $(IMPORTDIR)/merged_terms_combined.txt --force true --copy-ontology-annotations true --individuals exclude --method BOT \\\n396: \t\tremove $(patsubst %, --term %, $(ANNOTATION_PROPERTIES)) -T $(IMPORTDIR)/merged_terms_combined.txt --select complement --select annotation-properties \\\n397: \t\tquery --update ../sparql/inject-subset-declaration.ru --update ../sparql/inject-synonymtype-declaration.ru --update ../sparql/postprocess-module.ru \\\n398: \t\t$(ANNOTATE_CONVERT_FILE); fi\n399: \n400: \n401: \n402: \n403: $(IMPORTDIR)/%_import.owl: $(MIRRORDIR)/merged.owl $(IMPORTDIR)/%_terms_combined.txt\n404: \tif [ $(IMP) = true ]; then $(ROBOT) query -i $< --update ../sparql/preprocess-module.ru \\\n405: \t\textract -T $(IMPORTDIR)/$*_terms_combined.txt --force true --copy-ontology-annotations true --individuals exclude --method BOT \\\n406: \t\tquery --update ../sparql/inject-subset-declaration.ru --update ../sparql/inject-synonymtype-declaration.ru --update ../sparql/postprocess-module.ru \\\n407: \t\t$(ANNOTATE_CONVERT_FILE); fi\n408: \n409: .PRECIOUS: $(IMPORTDIR)/%_import.owl\n410: \n411: ## Module for ontology: orcidio\n412: \n413: $(IMPORTDIR)/orcidio_import.owl: $(MIRRORDIR)/merged.owl\n414: \techo \"ERROR: You have configured your default module type to be custom; this behavior needs to be overwritten in uberon.Makefile!\" && false\n415: ## Module for ontology: omo\n416: \n417: $(IMPORTDIR)/omo_import.owl: $(MIRRORDIR)/merged.owl $(IMPORTDIR)/omo_terms_combined.txt\n418: \tif [ $(IMP) = true ]; then $(ROBOT) merge -i $< query --update ../sparql/preprocess-module.ru --update ../sparql/inject-subset-declaration.ru --update ../sparql/inject-synonymtype-declaration.ru --update ../sparql/postprocess-module.ru  \\\n419:     $(ANNOTATE_CONVERT_FILE); fi\n420: \n421: \n422: .PHONY: refresh-imports\n423: refresh-imports:\n424: \t$(MAKE) IMP=true MIR=true PAT=false IMP_LARGE=true all_imports -B\n425: \n426: .PHONY: no-mirror-refresh-imports\n427: no-mirror-refresh-imports:\n428: \t$(MAKE) IMP=true MIR=false PAT=false IMP_LARGE=true all_imports -B\n429: \n430: .PHONY: refresh-imports-excluding-large\n431: refresh-imports-excluding-large:\n432: \t$(MAKE) IMP=true MIR=true PAT=false IMP_LARGE=false all_imports -B\n433: \n434: .PHONY: refresh-%\n435: refresh-%:\n436: \t$(MAKE) IMP=true IMP_LARGE=true MIR=true PAT=false $(IMPORTDIR)/$*_import.owl -B\n437: \n438: .PHONY: no-mirror-refresh-%\n439: no-mirror-refresh-%:\n440: \t$(MAKE) IMP=true IMP_LARGE=true MIR=false PAT=false $(IMPORTDIR)/$*_import.owl -B\n441: \n442: \n443: # ----------------------------------------\n444: # Components\n445: # ----------------------------------------\n446: # Some ontologies contain external and internal components. A component is included in the ontology in its entirety.\n447: \n448: COMP=true # Global parameter to bypass component generation\n449: \n450: .PHONY: all_components\n451: all_components: $(OTHER_SRC)\n452: \n453: .PHONY: recreate-components\n454: recreate-components:\n455: \t$(MAKE) COMP=true IMP=false MIR=true PAT=true IMP_LARGE=false all_components -B\n456: \n457: .PHONY: no-mirror-recreate-components\n458: no-mirror-recreate-components:\n459: \t$(MAKE) COMP=true IMP=false MIR=false PAT=true IMP_LARGE=false all_components -B\n460: \n461: .PHONY: recreate-%\n462: recreate-%:\n463: \t$(MAKE) COMP=true IMP=false IMP_LARGE=false MIR=true PAT=true $(COMPONENTSDIR)/$*.owl -B\n464: \n465: .PHONY: no-mirror-recreate-%\n466: no-mirror-recreate-%:\n467: \t$(MAKE) COMP=true IMP=false IMP_LARGE=false MIR=false PAT=true $(COMPONENTSDIR)/$*.owl -B\n468: \n469: $(COMPONENTSDIR)/%.owl: | $(COMPONENTSDIR)\n470: \ttest -f $@ || touch $@\n471: .PRECIOUS: $(COMPONENTSDIR)/%.owl\n472: \n473: \n474: \n475: \n476: \n477: \n478: \n479: # ----------------------------------------\n480: # Mirroring upstream ontologies\n481: # ----------------------------------------\n482: \n483: IMP=true # Global parameter to bypass import generation\n484: MIR=true # Global parameter to bypass mirror generation\n485: IMP_LARGE=true # Global parameter to bypass handling of large imports\n486: \n487: ifeq ($(strip $(MIR)),true)\n488: \n489: \n490: ## ONTOLOGY: pr\n491: .PHONY: mirror-pr\n492: .PRECIOUS: $(MIRRORDIR)/pr.owl\n493: mirror-pr: | $(TMPDIR)\n494: \t$(ROBOT) remove -I https://raw.githubusercontent.com/obophenotype/pro_obo_slim/master/pr_slim.owl --base-iri $(OBOBASE)/PR  --axioms external --preserve-structure false --trim false -o $(TMPDIR)/$@.owl\n495: \n496: \n497: ## ONTOLOGY: cl\n498: .PHONY: mirror-cl\n499: .PRECIOUS: $(MIRRORDIR)/cl.owl\n500: mirror-cl: | $(TMPDIR)\n501: \tcurl -L $(OBOBASE)/cl/cl-base.owl --create-dirs -o $(TMPDIR)/cl-download.owl --retry 4 --max-time 200 && \\\n502: \t$(ROBOT) convert -i $(TMPDIR)/cl-download.owl -o $(TMPDIR)/$@.owl\n503: \n504: \n505: ## ONTOLOGY: go\n506: .PHONY: mirror-go\n507: .PRECIOUS: $(MIRRORDIR)/go.owl\n508: mirror-go: | $(TMPDIR)\n509: \t$(ROBOT) remove -I http://purl.obolibrary.org/obo/go/go-base.owl --base-iri http://purl.obolibrary.org/obo/GO_ --base-iri http://purl.obolibrary.org/obo/GOREL_ --base-iri http://purl.obolibrary.org/obo/GOCHE_  --axioms external --preserve-structure false --trim false -o $(TMPDIR)/$@.owl\n510: \n511: \n512: ## ONTOLOGY: envo\n513: .PHONY: mirror-envo\n514: .PRECIOUS: $(MIRRORDIR)/envo.owl\n515: mirror-envo: | $(TMPDIR)\n516: \tcurl -L $(OBOBASE)/envo/envo-base.owl --create-dirs -o $(TMPDIR)/envo-download.owl --retry 4 --max-time 200 && \\\n517: \t$(ROBOT) convert -i $(TMPDIR)/envo-download.owl -o $(TMPDIR)/$@.owl\n518: \n519: \n520: ## ONTOLOGY: ro\n521: .PHONY: mirror-ro\n522: .PRECIOUS: $(MIRRORDIR)/ro.owl\n523: mirror-ro: | $(TMPDIR)\n524: \tcurl -L $(OBOBASE)/ro/ro-base.owl --create-dirs -o $(TMPDIR)/ro-download.owl --retry 4 --max-time 200 && \\\n525: \t$(ROBOT) convert -i $(TMPDIR)/ro-download.owl -o $(TMPDIR)/$@.owl\n526: \n527: \n528: ## ONTOLOGY: bspo\n529: .PHONY: mirror-bspo\n530: .PRECIOUS: $(MIRRORDIR)/bspo.owl\n531: mirror-bspo: | $(TMPDIR)\n532: \tcurl -L $(OBOBASE)/bspo/bspo-base.owl --create-dirs -o $(TMPDIR)/bspo-download.owl --retry 4 --max-time 200 && \\\n533: \t$(ROBOT) convert -i $(TMPDIR)/bspo-download.owl -o $(TMPDIR)/$@.owl\n534: \n535: \n536: ## ONTOLOGY: chebi\n537: .PHONY: mirror-chebi\n538: .PRECIOUS: $(MIRRORDIR)/chebi.owl\n539: mirror-chebi: | $(TMPDIR)\n540: \t$(ROBOT) remove -I https://raw.githubusercontent.com/obophenotype/chebi_obo_slim/main/chebi_slim.owl --base-iri $(OBOBASE)/CHEBI  --axioms external --preserve-structure false --trim false -o $(TMPDIR)/$@.owl\n541: \n542: \n543: ## ONTOLOGY: pato\n544: .PHONY: mirror-pato\n545: .PRECIOUS: $(MIRRORDIR)/pato.owl\n546: mirror-pato: | $(TMPDIR)\n547: \tcurl -L $(OBOBASE)/pato/pato-base.owl --create-dirs -o $(TMPDIR)/pato-download.owl --retry 4 --max-time 200 && \\\n548: \t$(ROBOT) convert -i $(TMPDIR)/pato-download.owl -o $(TMPDIR)/$@.owl\n549: \n550: \n551: ## ONTOLOGY: bfo\n552: .PHONY: mirror-bfo\n553: .PRECIOUS: $(MIRRORDIR)/bfo.owl\n554: mirror-bfo: | $(TMPDIR)\n555: \tcurl -L $(OBOBASE)/bfo.owl --create-dirs -o $(TMPDIR)/bfo-download.owl --retry 4 --max-time 200 && \\\n556: \t$(ROBOT) convert -i $(TMPDIR)/bfo-download.owl -o $(TMPDIR)/$@.owl\n557: \n558: \n559: ## ONTOLOGY: ncbitaxon\n560: .PHONY: mirror-ncbitaxon\n561: .PRECIOUS: $(MIRRORDIR)/ncbitaxon.owl\n562: mirror-ncbitaxon: | $(TMPDIR)\n563: \t$(ROBOT) convert -I http://purl.obolibrary.org/obo/ncbitaxon/subsets/taxslim.owl -o $(TMPDIR)/$@.owl\n564: \n565: \n566: ## ONTOLOGY: ncbitaxondisjoints\n567: .PHONY: mirror-ncbitaxondisjoints\n568: .PRECIOUS: $(MIRRORDIR)/ncbitaxondisjoints.owl\n569: mirror-ncbitaxondisjoints: | $(TMPDIR)\n570: \t$(ROBOT) convert -I http://purl.obolibrary.org/obo/ncbitaxon/subsets/taxslim-disjoint-over-in-taxon.owl -o $(TMPDIR)/$@.owl\n571: \n572: \n573: ## ONTOLOGY: nbo\n574: .PHONY: mirror-nbo\n575: .PRECIOUS: $(MIRRORDIR)/nbo.owl\n576: mirror-nbo: | $(TMPDIR)\n577: \tcurl -L $(OBOBASE)/nbo/nbo-base.owl --create-dirs -o $(TMPDIR)/nbo-download.owl --retry 4 --max-time 200 && \\\n578: \t$(ROBOT) convert -i $(TMPDIR)/nbo-download.owl -o $(TMPDIR)/$@.owl\n579: \n580: \n581: ## ONTOLOGY: orcidio\n582: .PHONY: mirror-orcidio\n583: .PRECIOUS: $(MIRRORDIR)/orcidio.owl\n584: mirror-orcidio: | $(TMPDIR)\n585: \t$(ROBOT) convert -I https://w3id.org/orcidio/orcidio.owl -o $(TMPDIR)/$@.owl\n586: \n587: \n588: ## ONTOLOGY: omo\n589: .PHONY: mirror-omo\n590: .PRECIOUS: $(MIRRORDIR)/omo.owl\n591: mirror-omo: | $(TMPDIR)\n592: \tcurl -L $(OBOBASE)/omo.owl --create-dirs -o $(TMPDIR)/omo-download.owl --retry 4 --max-time 200 && \\\n593: \t$(ROBOT) convert -i $(TMPDIR)/omo-download.owl -o $(TMPDIR)/$@.owl\n594: \n595: ALL_MIRRORS = $(patsubst %, $(MIRRORDIR)/%.owl, $(IMPORTS))\n596: MERGE_MIRRORS = true\n597: \n598: ifeq ($(strip $(MERGE_MIRRORS)),true)\n599: $(MIRRORDIR)/merged.owl: $(ALL_MIRRORS)\n600: \t$(ROBOT) merge $(patsubst %, -i %, $^)  -o $@\n601: .PRECIOUS: $(MIRRORDIR)/merged.owl\n602: endif\n603: \n604: \n605: $(MIRRORDIR)/%.owl: mirror-% | $(MIRRORDIR)\n606: \tif [ -f $(TMPDIR)/mirror-$*.owl ]; then if cmp -s $(TMPDIR)/mirror-$*.owl $@ ; then echo \"Mirror identical, ignoring.\"; else echo \"Mirrors different, updating.\" &&\\\n607: \t\tcp $(TMPDIR)/mirror-$*.owl $@; fi; fi\n608: \n609: else # MIR=false\n610: $(MIRRORDIR)/%.owl:\n611: \t@echo \"Not refreshing $@ because the mirrorring pipeline is disabled (MIR=$(MIR)).\"\n612: endif\n613: \n614: \n615: \n616: # ----------------------------------------\n617: # Subsets\n618: # ----------------------------------------\n619: $(SUBSETDIR)/%.tsv: $(SUBSETDIR)/%.owl\n620: \t$(ROBOT) query -f tsv -i $< -s ../sparql/labels.sparql $@\n621: .PRECIOUS: $(SUBSETDIR)/%.tsv\n622: \n623: $(SUBSETDIR)/%.owl: $(ONT).owl | $(SUBSETDIR)\n624: \t$(OWLTOOLS) $< --extract-ontology-subset --fill-gaps --subset $* -o $@.tmp.owl && mv $@.tmp.owl $@ &&\\\n625: \t$(ROBOT) annotate --input $@ --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) -o $@.tmp.owl && mv $@.tmp.owl $@\n626: .PRECIOUS: $(SUBSETDIR)/%.owl\n627: \n628: \n629: $(SUBSETDIR)/%.obo: $(SUBSETDIR)/%.owl\n630: \t$(ROBOT) convert --input $< --check false -f obo $(OBO_FORMAT_OPTIONS) -o $@.tmp.obo && grep -v ^owl-axioms $@.tmp.obo > $@ && rm $@.tmp.obo\n631: \n632: $(SUBSETDIR)/%.json: $(SUBSETDIR)/%.owl\n633: \t$(ROBOT) convert --input $< --check false -f json -o $@.tmp.json &&\\\n634: \tmv $@.tmp.json $@\n635: \n636: \n637: # ---------------------------------------------\n638: # Sparql queries: Table exports / Query Reports\n639: # ---------------------------------------------\n640: \n641: SPARQL_EXPORTS_ARGS = $(foreach V,$(SPARQL_EXPORTS),-s $(SPARQLDIR)/$(V).sparql $(REPORTDIR)/$(V).tsv)\n642: # This combines all into one single command\n643: \n644: .PHONY: custom_reports\n645: custom_reports: $(EDIT_PREPROCESSED) | $(REPORTDIR)\n646: ifneq ($(SPARQL_EXPORTS_ARGS),)\n647: \t$(ROBOT) query -f tsv --use-graphs true -i $< $(SPARQL_EXPORTS_ARGS)\n648: endif\n649: # ----------------------------------------\n650: # DOSDP Templates/Patterns\n651: # ----------------------------------------\n652: \n653: PAT=true # Global parameter to bypass pattern generation\n654: ALL_PATTERN_FILES=$(wildcard $(PATTERNDIR)/dosdp-patterns/*.yaml)\n655: ALL_PATTERN_NAMES=$(strip $(patsubst %.yaml,%, $(notdir $(wildcard $(PATTERNDIR)/dosdp-patterns/*.yaml))))\n656: \n657: PATTERN_CLEAN_FILES=../patterns/all_pattern_terms.txt \\\n658: \t$(DOSDP_OWL_FILES_DEFAULT) $(DOSDP_TERM_FILES_DEFAULT) \\\n659: \t\n660: \n661: # Note to future generations: prepending ./ is a safety measure to ensure that \n662: # the environment does not malicously set `PATTERN_CLEAN_FILES` to `\\`.\n663: .PHONY: pattern_clean\n664: pattern_clean:\n665: \trm -f $(PATTERN_CLEAN_FILES)\n666: \n667: .PHONY: patterns\n668: patterns dosdp:\n669: \techo \"Validating all DOSDP templates\"\n670: \t$(MAKE) dosdp_validation\n671: \techo \"Building $(PATTERNDIR)/definitions.owl\"\n672: \t$(MAKE) $(PATTERNDIR)/pattern.owl $(PATTERNDIR)/definitions.owl\n673: \n674: # DOSDP Template Validation\n675: \n676: $(TMPDIR)/pattern_schema_checks: $(ALL_PATTERN_FILES) | $(TMPDIR)\n677: \t$(PATTERN_TESTER) $(PATTERNDIR)/dosdp-patterns/ && touch $@\n678: \n679: .PHONY: pattern_schema_checks\n680: pattern_schema_checks dosdp_validation: $(TMPDIR)/pattern_schema_checks\n681: \n682: .PHONY: update_patterns\n683: update_patterns: download_patterns\n684: \tif [ -n \"$$(find $(TMPDIR) -type f -path '$(TMPDIR)/dosdp/*.yaml')\" ]; then cp -r $(TMPDIR)/dosdp/*.yaml $(PATTERNDIR)/dosdp-patterns; fi\n685: \n686: # This command is a workaround for the absence of -N and -i in wget of alpine (the one ODK depend on now).\n687: # It downloads all patterns specified in external.txt\n688: .PHONY: download_patterns\n689: download_patterns:\n690: \tif [ $(PAT) = true ]; then rm -f $(TMPDIR)/dosdp/*.yaml.1 || true; fi\n691: \tif [ $(PAT) = true ] && [ -s $(PATTERNDIR)/dosdp-patterns/external.txt ]; then wget -i $(PATTERNDIR)/dosdp-patterns/external.txt --backups=1 -P $(TMPDIR)/dosdp; fi\n692: \tif [ $(PAT) = true ]; then rm -f $(TMPDIR)/dosdp/*.yaml.1 || true; fi\n693: \n694: $(PATTERNDIR)/dospd-patterns/%.yml: download_patterns\n695: \tif [ $(PAT) = true ] ; then if cmp -s $(TMPDIR)/dosdp-$*.yml $@ ; then echo \"DOSDP templates identical.\"; else echo \"DOSDP templates different, updating.\" &&\\\n696: \t\tcp $(TMPDIR)/dosdp-$*.yml $@; fi; fi\n697: \n698: \n699: # DOSDP Template: Pipelines\n700: # Each pipeline gets its own directory structure\n701: \n702: # DOSDP default pipeline\n703: \n704: DOSDP_TSV_FILES_DEFAULT = $(wildcard $(PATTERNDIR)/data/default/*.tsv)\n705: DOSDP_OWL_FILES_DEFAULT = $(patsubst %.tsv, $(PATTERNDIR)/data/default/%.ofn, $(notdir $(wildcard $(PATTERNDIR)/data/default/*.tsv)))\n706: DOSDP_TERM_FILES_DEFAULT = $(patsubst %.tsv, $(PATTERNDIR)/data/default/%.txt, $(notdir $(wildcard $(PATTERNDIR)/data/default/*.tsv)))\n707: DOSDP_PATTERN_NAMES_DEFAULT = $(strip $(patsubst %.tsv,%, $(notdir $(wildcard $(PATTERNDIR)/data/default/*.tsv))))\n708: \n709: $(DOSDP_OWL_FILES_DEFAULT): $(EDIT_PREPROCESSED) $(DOSDP_TSV_FILES_DEFAULT) $(ALL_PATTERN_FILES)\n710: \tif [ $(PAT) = true ] && [ \"${DOSDP_PATTERN_NAMES_DEFAULT}\" ]; then $(DOSDPT) generate --catalog=$(CATALOG) \\\n711:     --infile=$(PATTERNDIR)/data/default/ --template=$(PATTERNDIR)/dosdp-patterns --batch-patterns=\"$(DOSDP_PATTERN_NAMES_DEFAULT)\" \\\n712:     --ontology=$< --obo-prefixes=true --outfile=$(PATTERNDIR)/data/default; fi\n713: \n714: \n715: # Generate template file seeds\n716: \n717: ## Generate template file seeds\n718: $(PATTERNDIR)/data/default/%.txt: $(PATTERNDIR)/dosdp-patterns/%.yaml $(PATTERNDIR)/data/default/%.tsv\n719: \tif [ $(PAT) = true ]; then $(DOSDPT) terms --infile=$(word 2, $^) --template=$< --obo-prefixes=true --outfile=$@; fi\n720: \n721: \n722: # Generating the seed file from all the TSVs. If Pattern generation is deactivated, we still extract a seed from definitions.owl\n723: $(TMPDIR)/all_pattern_terms.txt: $(DOSDP_TERM_FILES_DEFAULT)   $(TMPDIR)/pattern_owl_seed.txt\n724: \tif [ $(PAT) = true ]; then cat $^ | sort | uniq > $@; else $(ROBOT) query --use-graphs true -f csv -i $(PATTERNDIR)/definitions.owl \\\n725:     --query ../sparql/terms.sparql $@; fi\n726: \n727: $(TMPDIR)/pattern_owl_seed.txt: $(PATTERNDIR)/pattern.owl\n728: \tif [ $(PAT) = true ]; then $(ROBOT) query --use-graphs true -f csv -i $< --query ../sparql/terms.sparql $@; fi\n729: \n730: # Pattern pipeline main targets: the generated OWL files\n731: \n732: # Create pattern.owl, an ontology of all DOSDP patterns\n733: $(PATTERNDIR)/pattern.owl: $(ALL_PATTERN_FILES)\n734: \tif [ $(PAT) = true ]; then $(DOSDPT) prototype --obo-prefixes true --template=$(PATTERNDIR)/dosdp-patterns --outfile=$@; fi\n735: \n736: # Generating the individual pattern modules and merging them into definitions.owl\n737: $(PATTERNDIR)/definitions.owl: $(DOSDP_OWL_FILES_DEFAULT)  \n738: \tif [ $(PAT) = true ] && [ \"${DOSDP_PATTERN_NAMES_DEFAULT}\" ]   && [ $(PAT) = true ]; then $(ROBOT) merge $(addprefix -i , $^) \\\n739: \t\tannotate --ontology-iri $(ONTBASE)/patterns/definitions.owl  --version-iri $(ONTBASE)/releases/$(TODAY)/patterns/definitions.owl \\\n740:       --annotation owl:versionInfo $(VERSION) -o definitions.ofn && mv definitions.ofn $@; fi\n741: \n742: \n743: # ----------------------------------------\n744: # SSSOM Mapping Files\n745: # ----------------------------------------\n746: \n747: validate-sssom-%:\n748: \ttsvalid $(MAPPINGDIR)/$*.sssom.tsv --comment \"#\"\n749: \tsssom validate $(MAPPINGDIR)/$*.sssom.tsv\n750: \n751: # This mappingset is manually curated, so we only check that the file actually exists.\n752: $(MAPPINGDIR)/fbbt.sssom.tsv:\n753: \ttest -f $@\n754: \n755: # This mappingset is manually curated, so we only check that the file actually exists.\n756: $(MAPPINGDIR)/cl.sssom.tsv:\n757: \ttest -f $@\n758: \n759: # This mappingset is manually curated, so we only check that the file actually exists.\n760: $(MAPPINGDIR)/sslso.sssom.tsv:\n761: \ttest -f $@\n762: \n763: # This mappingset is manually curated, so we only check that the file actually exists.\n764: $(MAPPINGDIR)/biomappings.sssom.tsv:\n765: \ttest -f $@\n766: \n767: # This mappingset is manually curated, so we only check that the file actually exists.\n768: $(MAPPINGDIR)/uberon-local.sssom.tsv:\n769: \ttest -f $@\n770: \n771: # This mappingset is manually curated, so we only check that the file actually exists.\n772: $(MAPPINGDIR)/uberon.sssom.tsv:\n773: \ttest -f $@\n774: \n775: # This mappingset is manually curated, so we only check that the file actually exists.\n776: $(MAPPINGDIR)/import-corrections.sssom.tsv:\n777: \ttest -f $@\n778: \n779: validate_mappings:\n780: \t$(MAKE_FAST) $(foreach n,$(MAPPINGS), validate-sssom-$(n))\n781: \n782: \n783: \n784: # ----------------------------------------\n785: # Release artefacts: export formats\n786: # ----------------------------------------\n787: \n788: \n789: $(ONT)-base.obo: $(ONT)-base.owl\n790: \t$(ROBOT) convert --input $< --check false -f obo $(OBO_FORMAT_OPTIONS)