.tmp.obo > $@ && rm $@.tmp.obo\n845: collected-lifestages.json: collected-lifestages.owl\n846: \t$(ROBOT) annotate --input $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n847: \t\tconvert --check false -f json -o $@.tmp.json &&\\\n848: \t\tmv $@.tmp.json $@\n849: composite-lifestages.obo: composite-lifestages.owl\n850: \t$(ROBOT) convert --input $< --check false -f obo $(OBO_FORMAT_OPTIONS) -o $@.tmp.obo && grep -v ^owl-axioms $@.tmp.obo > $@ && rm $@.tmp.obo\n851: composite-lifestages.json: composite-lifestages.owl\n852: \t$(ROBOT) annotate --input $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n853: \t\tconvert --check false -f json -o $@.tmp.json &&\\\n854: \t\tmv $@.tmp.json $@\n855: common-anatomy.obo: common-anatomy.owl\n856: \t$(ROBOT) convert --input $< --check false -f obo $(OBO_FORMAT_OPTIONS) -o $@.tmp.obo && grep -v ^owl-axioms $@.tmp.obo > $@ && rm $@.tmp.obo\n857: common-anatomy.json: common-anatomy.owl\n858: \t$(ROBOT) annotate --input $< --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n859: \t\tconvert --check false -f json -o $@.tmp.json &&\\\n860: \t\tmv $@.tmp.json $@\n861: # ----------------------------------------\n862: # Release artefacts: main release artefacts\n863: # ----------------------------------------\n864: \n865: $(ONT).owl: $(ONT)-full.owl\n866: \t$(ROBOT) annotate --input $< --ontology-iri $(URIBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n867: \t\tconvert -o $@.tmp.owl && mv $@.tmp.owl $@\n868: \n869: $(ONT).obo: $(ONT).owl\n870: \t$(ROBOT) convert --input $< --check false -f obo $(OBO_FORMAT_OPTIONS) -o $@.tmp.obo && grep -v ^owl-axioms $@.tmp.obo > $@ && rm $@.tmp.obo\n871: $(ONT).json: $(ONT).owl\n872: \t$(ROBOT) annotate --input $< --ontology-iri $(URIBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n873: \t\tconvert --check false -f json -o $@.tmp.json &&\\\n874: \t\tmv $@.tmp.json $@\n875: # -----------------------------------------------------\n876: # Release artefacts: variants (base, full, simple, etc)\n877: # -----------------------------------------------------\n878: SHARED_ROBOT_COMMANDS = \n879: \n880: $(ONTOLOGYTERMS): $(SRCMERGED)\n881: \t$(ROBOT) query -f csv -i $< --query ../sparql/uberon_terms.sparql $@\n882: \n883: # ROBOT pipeline that merges imports, including components.\n884: ROBOT_RELEASE_IMPORT_MODE=$(ROBOT) merge --input $< \n885: \n886: # ROBOT pipeline that removes imports, then merges components. This is for release artefacts that start from \"base\"\n887: ROBOT_RELEASE_IMPORT_MODE_BASE=$(ROBOT) remove --input $< --select imports --trim false merge $(patsubst %, -i %, $(OTHER_SRC)) \n888: \n889: # base: A version of the ontology that does not include any externally imported axioms.\n890: $(ONT)-base.owl: $(EDIT_PREPROCESSED) $(OTHER_SRC) $(IMPORT_FILES)\n891: \t$(ROBOT_RELEASE_IMPORT_MODE) \\\n892: \treason --reasoner ELK --equivalent-classes-allowed asserted-only --exclude-tautologies structural --annotate-inferred-axioms False \\\n893: \trelax \\\n894: \treduce -r ELK \\\n895: \tremove --base-iri http://purl.obolibrary.org/obo/UBERON_ --base-iri http://purl.obolibrary.org/obo/uberon# --base-iri http://purl.obolibrary.org/obo/UBPROP_ --base-iri http://purl.obolibrary.org/obo/uberon/core# --axioms external --preserve-structure false --trim false \\\n896: \t$(SHARED_ROBOT_COMMANDS) \\\n897: \tannotate --link-annotation http://purl.org/dc/elements/1.1/type http://purl.obolibrary.org/obo/IAO_8000001 \\\n898: \t\t--ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) \\\n899: \t\t--output $@.tmp.owl && mv $@.tmp.owl $@\n900: # Full: The full artefacts with imports merged, reasoned.\n901: $(ONT)-full.owl: $(EDIT_PREPROCESSED) $(OTHER_SRC) $(IMPORT_FILES)\n902: \t$(ROBOT_RELEASE_IMPORT_MODE) \\\n903: \t\treason --reasoner ELK --equivalent-classes-allowed asserted-only --exclude-tautologies structural \\\n904: \t\trelax \\\n905: \t\treduce -r ELK \\\n906: \t\t$(SHARED_ROBOT_COMMANDS) annotate --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) --output $@.tmp.owl && mv $@.tmp.owl $@\n907: # foo-simple: (edit->reason,relax,reduce,drop imports, drop every axiom which contains an entity outside the \"namespaces of interest\")\n908: # drop every axiom: filter --term-file keep_terms.txt --trim true\n909: #\tremove --select imports --trim false\n910: $(ONT)-simple.owl: $(EDIT_PREPROCESSED) $(OTHER_SRC) $(SIMPLESEED) $(IMPORT_FILES)\n911: \t$(ROBOT_RELEASE_IMPORT_MODE) \\\n912: \t\treason --reasoner ELK --equivalent-classes-allowed asserted-only --exclude-tautologies structural --annotate-inferred-axioms False \\\n913: \t\trelax \\\n914: \t\tremove --axioms equivalent \\\n915: \t\trelax \\\n916: \t\tfilter --term-file $(SIMPLESEED) --select \"annotations ontology anonymous self\" --trim true --signature true \\\n917: \t\treduce -r ELK \\\n918: \t\tquery --update ../sparql/inject-subset-declaration.ru --update ../sparql/inject-synonymtype-declaration.ru \\\n919: \t\t$(SHARED_ROBOT_COMMANDS) annotate --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) --output $@.tmp.owl && mv $@.tmp.owl $@\n920: \n921: # foo-basic: A version of -simple containing only relationships using relations on a configurable whitelist (default = BFO:0000050 (?)). \n922: # See above (David comment) for explanation.\n923: # removes any axioms that contains one of the ops that not in the whitelist file\n924: $(ONT)-basic.owl: $(EDIT_PREPROCESSED) $(OTHER_SRC) $(SIMPLESEED) $(KEEPRELATIONS) $(IMPORT_FILES)\n925: \t$(ROBOT_RELEASE_IMPORT_MODE) \\\n926: \t\treason --reasoner ELK --equivalent-classes-allowed asserted-only --exclude-tautologies structural --annotate-inferred-axioms False \\\n927: \t\trelax \\\n928: \t\tremove --axioms equivalent \\\n929: \t\tremove --axioms disjoint \\\n930: \t\tremove --term-file $(KEEPRELATIONS) --select complement --select object-properties --trim true \\\n931: \t\trelax \\\n932: \t\tfilter --term-file $(SIMPLESEED) --select \"annotations ontology anonymous self\" --trim true --signature true \\\n933: \t\treduce -r ELK \\\n934: \t\t$(SHARED_ROBOT_COMMANDS) annotate --ontology-iri $(ONTBASE)/$@ $(ANNOTATE_ONTOLOGY_VERSION) --output $@.tmp.owl && mv $@.tmp.owl $@\n935: \n936: collected-metazoan.owl:\n937: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n938: \n939: composite-metazoan.owl:\n940: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n941: \n942: composite-metazoan-basic.owl:\n943: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n944: \n945: composite-vertebrate.owl:\n946: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n947: \n948: composite-vertebrate-basic.owl:\n949: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n950: \n951: collected-lifestages.owl:\n952: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n953: \n954: composite-lifestages.owl:\n955: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n956: \n957: common-anatomy.owl:\n958: \techo \"ERROR: You have configured a custom release artefact ($@); this release artefact needs to be define in uberon.Makefile!\" && false\n959: # ----------------------------------------\n960: # Debugging Tools\n961: # ----------------------------------------\n962: \n963: explain_unsat: $(EDIT_PREPROCESSED) \n964: \t$(ROBOT) explain -i $< -M unsatisfiability --unsatisfiable random:10 --explanation $(TMPDIR)/$@.md\n965: \n966: \n967: \n968: RELEASE_ASSETS_AFTER_RELEASE=$(foreach n,$(RELEASE_ASSETS), ../../$(n))\n969: GHVERSION=v$(VERSION)\n970: \n971: .PHONY: public_release\n972: public_release:\n973: \t@test $(GHVERSION)\n974: \tls -alt $(RELEASE_ASSETS_AFTER_RELEASE)\n975: \tgh release create $(GHVERSION) --title \"$(VERSION) Release\" --draft $(RELEASE_ASSETS_AFTER_RELEASE) --generate-notes\n976: \n977: # ----------------------------------------\n978: # General Validation\n979: # ----------------------------------------\n980: TSV=\n981: ALL_TSV_FILES=$(DOSDP_TSV_FILES_DEFAULT)\n982: \n983: validate-tsv: $(TSV) | $(TMPDIR)\n984: \tfor FILE in $< ; do \\\n985: \t\ttsvalid $$FILE > $(TMPDIR)/validate.txt; \\\n986: \t\tif [ -s $(TMPDIR)/validate.txt ]; then cat $(TMPDIR)/validate.txt && exit 1; fi ; \\\n987: \tdone\n988: \n989: validate-all-tsv: $(ALL_TSV_FILES)\n990: \t$(MAKE) validate-tsv TSV=\"$^\"\n991: \n992: # ----------------------------------------\n993: # Editors Utilities\n994: # ----------------------------------------\n995: \n996: .PHONY: normalize_obo_src\n997: normalize_obo_src: $(SRC)\n998: \t$(OWLTOOLS) $< --merge-axiom-annotations -o -f obo $(TMPDIR)/NORM.obo &&\\\n999: \t$(ROBOT) convert -i $(TMPDIR)/NORM.obo -o $(TMPDIR)/NORM.tmp.obo &&\\\n1000: \tmv $(TMPDIR)/NORM.tmp.obo $(SRC)\n1001: \n1002: .PHONY: normalize_src\n1003: normalize_src: $(SRC)\n1004: \t$(ROBOT) convert -i $< -f obo --check false -o $(TMPDIR)/normalise && mv $(TMPDIR)/normalise $<\n1005: \n1006: .PHONY: validate_idranges\n1007: validate_idranges:\n1008: \tamm $(SCRIPTSDIR)/validate_id_ranges.sc uberon-idranges.owl\n1009: \n1010: .PHONY: update_repo\n1011: update_repo:\n1012: \tsh $(SCRIPTSDIR)/update_repo.sh\n1013: \t\n1014: \n1015: update_docs:\n1016: \tmkdocs gh-deploy --config-file ../../mkdocs.yaml\n1017: \n1018: # Note to future generations: computing the real path relative to the\n1019: # current directory is a way to ensure we only clean up directories that\n1020: # are located below the current directory, regardless of the contents of\n1021: # the *DIR variables.\n1022: .PHONY: clean\n1023: clean:\n1024: \t$(MAKE) pattern_clean\n1025: \tfor dir in $(MIRRORDIR) $(TMPDIR) $(UPDATEREPODIR) ; do      \\\n1026: \t\treldir=$$(realpath --relative-to=$$(pwd) $$dir) ;    \\\n1027: \t\tcase $$reldir in .*|\"\") ;; *) rm -rf $$reldir/* ;; esac \\\n1028: \tdone\n1029: \trm -f $(CLEANFILES)\n1030: \n1031: .PHONY: help\n1032: help:\n1033: \t@echo \"$$data\"\n1034: \n1035: define data\n1036: Usage: [IMAGE=(odklite|odkfull)] [ODK_DEBUG=yes] sh run.sh make [(IMP|MIR|IMP_LARGE|PAT)=(false|true)] command\n1037: \n1038: ----------------------------------------\n1039: \tCommand reference\n1040: ----------------------------------------\n1041: \n1042: Core commands:\n1043: * prepare_release:\tRun the entire release pipeline. Use make IMP=false prepare_release to avoid rerunning the imports\n1044: * prepare_release_fast:\tRun the entire release pipeline without refreshing imports, recreating components or recompiling patterns.\n1045: * update_repo:\t\tUpdate the ODK repository setup using the config file uberon-odk.yaml\n1046: * test:\t\t\tRunning all validation tests\n1047: * test_fast:\t\tRuns the test suite, but without updating imports or components\n1048: * odkversion:\t\tShow the current version of the ODK Makefile and ROBOT.\n1049: * clean:\t\tDelete all temporary files\n1050: * help:\t\t\tPrint ODK Usage information\n1051: * public_release:\tUploads the release file to a release management system, such as GitHub releases. Must be configured.\n1052: \n1053: \n1054: Imports management:\n1055: * refresh-imports:\t\t\tRefresh all imports and mirrors.\n1056: * recreate-components:\t\t\tRecreate all components.\n1057: * no-mirror-refresh-imports:\t\tRefresh all imports without downloading mirrors.\n1058: * refresh-imports-excluding-large:\tRefresh all imports and mirrors, but skipping the ones labelled as 'is_large'.\n1059: * refresh-%:\t\t\t\tRefresh a single import, i.e. refresh-go will refresh 'imports/go_import.owl'.\n1060: * no-mirror-refresh-%:\t\t\tRefresh a single import without updating the mirror, i.e. refresh-go will refresh 'imports/go_import.owl'.\n1061: * mirror-%:\t\t\t\tRefresh a single mirror.\n1062: \n1063: DOSDP templates\n1064: * dosdp:\t\t\tRun the DOSDP patterns pipeline: Run tests, then build OWL files from the tables.\n1065: * patterns:\t\t\tAlias of the 'dosdp' command\n1066: * pattern_clean:\t\tDelete all temporary pattern files\n1067: * dosdp_validation:\t\tRun all validation checks on DOSDP template files and tables\n1068: * pattern_schema_checks:\tAlias of the 'dosdp_validation' command\n1069: * update_patterns:\t\tPull updated patterns listed in dosdp-patterns/external.txt\n1070: * dosdp-matches-%:\t\tRun the DOSDP matches/query pipeline as configured in your uberon-odk.yaml file.\n1071: \n1072: Editor utilities:\n1073: * validate_idranges:\tMake sure your ID ranges file is formatted correctly\n1074: * normalize_src:\tLoad and save your uberon-edit file after you to make sure its serialised correctly\n1075: * normalize_obo_src:\tLoad and save your uberon-edit.obo file after you to merge duplicate annotation assertions\n1076: * explain_unsat:\tIf you have unsatisfiable classes, this command will create a markdown file (tmp/explain_unsat.md) which will explain all your unsatisfiable classes\n1077: * validate-all-tsv:\tCheck all your tsv files for possible problems in syntax. Use ALL_TSV_FILES variable to list files\n1078: * validate-tsv:\t\tCheck a tsv file for syntactic problems with tsvalid. Use TSV variable to pass filepath, e.g. make TSV=../my.tsv validate-tsv.\n1079: * release_diff:\tCreate a diff between the current release and the new release\n1080: \n1081: Additional build commands (advanced users)\n1082: * all:\t\t\tRun the entire pipeline (like prepare_release), but without copying the release files to the release directory.\n1083: * all_subsets:\t\tBuild all subsets\n1084: * custom_reports:\tGenerate all custom sparql reports you have configured in your uberon-odk.yaml file.\n1085: * all_assets:\t\tBuild all assets\n1086: * show_assets:\t\tPrint a list of all assets that would be build by the release pipeline\n1087: * all_mappings:\t\tUpdate all SSSOM mapping sets\n1088: \n1089: Additional QC commands (advanced users)\n1090: * robot_reports:\tRun all configured ROBOT reports\n1091: * validate_profile_%:\tRun an OWL2 DL profile validation check, for example validate_profile_uberon-edit.owl.\n1092: * reason_test: Run a basic reasoning test\n1093: \n1094: Examples: \n1095: * sh run.sh make IMP=false prepare_release\n1096: * sh run.sh make update_repo\n1097: * sh run.sh make test\n1098: \n1099: Tricks:\n1100: * Add -B to the end of your command to force re-running it even if nothing has changed\n1101: * Use the IMAGE parameter to the run.sh script to use a different image like odklite\n1102: * Use ODK_DEBUG=yes sh run.sh make ... to print information about timing and debugging\n1103: \n1104: endef\n1105: export data\n1106: \n1107: include uberon.Makefile\n\n(End of file - total 1107 lines)\n</content>","metadata":{"preview":"# ----------------------------------------\n# Makefile for uberon\n# Generated using ontology-development-kit\n# ODK Version: v1.5.4\n# ----------------------------------------\n# IMPORTANT: DO NOT EDIT THIS FILE. To override default make goals, use uberon.Makefile instead\n\n\n# ----------------------------------------\n# More information: https://github.com/INCATools/ontology-development-kit/\n\n# Fingerprint of the configuration file when this Makefile was last generated\nCONFIG_HASH=                2280340b1810b2a972296e0c511d5e87711793855300136263ac0b8801de9cf3\n\n\n# ----------------------------------------\n# Standard Constants\n# ----------------------------------------\n# these can be overwritten on the command line\n","truncated":false,"loaded":[]},"title":"src/ontology/Makefile","time":{"start":1778903954214,"end":1778903954220}},"id":"prt_e2ef0328e001lDlU4KPiFnBhcZ","sessionID":"ses_