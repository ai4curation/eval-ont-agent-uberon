:84023]\nsynonym: \"nucleus corporis trapezoidei\" RELATED OMO:0003011 [NeuroNames:576]\nsynonym: \"nucleus of the trapezoid body\" RELATED [BAMS:NTB, BAMS:Tz]\nsynonym: \"nucleus trapezoidalis\" RELATED OMO:0003011 [NeuroNames:576]\nsynonym: \"set of nuclei of trapezoid body\" RELATED [FMA:84023]\nsynonym: \"trapezoid gray\" RELATED [BIRNLEX:745]\nsynonym: \"trapezoid nuclear complex\" EXACT [BIRNLEX:745]\nsynonym: \"trapezoid nuclei\" RELATED [BIRNLEX:745]\nsynonym: \"Tz\" BROAD OMO:0003000 [BIRNLEX:745, NIFSTD:NeuroNames_abbrevSource]\nxref: BAMS:NTB\nxref: BAMS:Tz\nxref: BIRNLEX:745\nxref: BM:NTB\nxref: DHBA:12458\nxref: EMAPA:35600\nxref: FMA:84023\nxref: HBA:9185\nxref: MA:0001018\nxref: MBA:642\nxref: neuronames:576 {source=\"BIRNLEX:745\"}\nxref: SCTID:362405000\nxref: UMLS:C0228436 {source=\"BIRNLEX:745\"}\nxref: UMLS:C1289449 {source=\"BIRNLEX:745\"}\nis_a: UBERON:0006331 {source=\"MA\"} ! brainstem nucleus\nrelationship: located_in UBERON:0002932 ! trapezoid body\nrelationship: mutually_spatially_disjoint_with UBERON:0002126 {source=\"ABA\"} ! solitary tract nuclear complex\nrelationship: mutually_spatially_disjoint_with UBERON:0002162 {source=\"ABA\"} ! area postrema\nrelationship: mutually_spatially_disjoint_with UBERON:0002591 {source=\"ABA\"} ! oral part of spinal trigeminal nucleus\nrelationship: mutually_spatially_disjoint_with UBERON:0002610 {source=\"ABA\"} ! cochlear nuclear complex\nrelationship: mutually_spatially_disjoint_with UBERON:0002864 {source=\"ABA\"} ! accessory cuneate nucleus\nrelationship: mutually_spatially_disjoint_with UBERON:0002866 {source=\"ABA\"} ! caudal part of spinal trigeminal nucleus\nrelationship: mutually_spatially_disjoint_with UBERON:0002873 {source=\"ABA\"} ! interpolar part of spinal trigeminal nucleus\nrelationship: part_of UBERON:0000988 {source=\"MA\"} ! pons\nrelationship: part_of UBERON:0002128 {source=\"NIFSTD\"} ! superior olivary complex\n\n","exit":0,"description":"Searches ontology for related kidney region terms","truncated":false},"title":"Searches ontology for related kidney region terms","time":{"start":1778980418871,"end":1778980418879}},"id":"prt_e337ef48f001Hg3VLF1gn99s5D","sessionID":"ses_1cc81798affeY6djrRh3to6wSK","messageID":"msg_e337ed638001LFsS2MMpzYfvYG"}}
