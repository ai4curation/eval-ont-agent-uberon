dits via terms checkout/checkin workflow","status":"pending","priority":"high"},{"content":"Run ontology validation/reserialization as feasible","status":"pending","priority":"high"},{"content":"Commit only edited ontology changes locally","status":"pending","priority":"high"},{"content":"Create uncommitted ISSUE_COMMENTS.md and PR_COMMENTS.md","status":"pending","priority":"high"}],"truncated":false},"title":"5 todos","time":{"start":1778975765330,"end":1778975765336}},"id":"prt_e3337e7e8001sS84fI2CjoOQLo","sessionID":"ses_1ccc874caffeiQTf8QGzV3WBOa","messageID":"msg_e3337dddc0017LxnYmb0EqfyWJ"}}
